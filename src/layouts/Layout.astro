---
import "../styles/global.css";

interface Props {
  title?: string;
  wide?: boolean;
}

const { title = "سَقِیفَه", wide = false } = Astro.props;
---

<!doctype html>
<html lang="fa" dir="rtl">
  <head>
    <script>document.documentElement.dataset.theme=localStorage.getItem("theme")==="light"?"light":"dark"</script>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Vazirmatn:wght@400;500;700;800;900&display=swap"
      rel="stylesheet"
    />
    <script src="https://code.iconify.design/3/3.1.0/iconify.min.js"></script>
  </head>
  <body>
    <main class:list={["page-shell", wide && "page-shell--wide"]}>
      <slot />
    </main>
  </body>
</html>