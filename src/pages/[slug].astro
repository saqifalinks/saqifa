---
export const prerender = false;

import Layout from '../layouts/Layout.astro';
import { isSupabaseConfigured, supabase } from "../lib/supabase";

const { slug } = Astro.params;

type Category = { id: string; name: string; slug: string; icon_name: string; };
type Link     = { id: string; platform: string; url: string; display_order: number; };
type Entity   = { id: string; name: string; title: string | null; description: string | null; avatar_url: string | null; is_verified: boolean; links: Link[]; };

let category: Category | null = null;
let entities: Entity[] = [];
let allCategories: Category[] = [];
let pageError = "";

if (isSupabaseConfigured && supabase) {
  const [{ data: catData, error: catError }, { data: allCats }] = await Promise.all([
    supabase.from("categories").select("id,name,slug,icon_name").eq("slug", slug).single(),
    supabase.from("categories").select("id,name,slug,icon_name").order("display_order", { ascending: true }),
  ]);

  allCategories = (allCats ?? []) as Category[];

  if (catError || !catData) {
    pageError = "دسته‌بندی یافت نشد.";
  } else {
    category = catData as Category;
    const { data: entitiesData, error: entitiesError } = await supabase
      .from("entities")
      .select("id,name,title,description,avatar_url,is_verified,links(id,platform,url,display_order)")
      .eq("category_id", category.id)
      .order("created_at", { ascending: true });

    if (entitiesError) {
      pageError = "خطا در دریافت اطلاعات.";
    } else {
      entities = (entitiesData ?? []).map((e: any) => ({
        ...e,
        links: (e.links ?? []).sort((a: Link, b: Link) => a.display_order - b.display_order),
      }));
    }
  }
}

const platformMap: Record<string, { icon: string; brand: boolean; label: string; color: string }> = {
  telegram:   { icon: "fa-telegram",      brand: true,  label: "تلگرام",      color: "#29B6F6" },
  youtube:    { icon: "fa-youtube",        brand: true,  label: "یوتیوب",      color: "#FF0000" },
  instagram:  { icon: "fa-instagram",      brand: true,  label: "اینستاگرام",  color: "#E1306C" },
  twitter:    { icon: "fa-twitter",        brand: true,  label: "توییتر",      color: "#1DA1F2" },
  x:          { icon: "fa-x-twitter",      brand: true,  label: "ایکس",        color: "#222222" },
  website:    { icon: "fa-globe",          brand: false, label: "وبسایت",      color: "#4CAF50" },
  site:       { icon: "fa-globe",          brand: false, label: "وبسایت",      color: "#4CAF50" },
  soundcloud: { icon: "fa-soundcloud",     brand: true,  label: "ساندکلاد",    color: "#FF5500" },
  spotify:    { icon: "fa-spotify",        brand: true,  label: "اسپاتیفای",   color: "#1DB954" },
  facebook:   { icon: "fa-facebook",       brand: true,  label: "فیسبوک",      color: "#1877F2" },
  whatsapp:   { icon: "fa-whatsapp",       brand: true,  label: "واتساپ",      color: "#25D366" },
  aparat:     { icon: "fa-play-circle",    brand: false, label: "آپارات",      color: "#E7194B" },
  linkedin:   { icon: "fa-linkedin",       brand: true,  label: "لینکدین",     color: "#0A66C2" },
  tiktok:     { icon: "fa-tiktok",         brand: true,  label: "تیک‌تاک",     color: "#010101" },
  pinterest:  { icon: "fa-pinterest",      brand: true,  label: "پینترست",     color: "#E60023" },
  discord:    { icon: "fa-discord",        brand: true,  label: "دیسکورد",     color: "#5865F2" },
  twitch:     { icon: "fa-twitch",         brand: true,  label: "توییچ",       color: "#9146FF" },
  reddit:     { icon: "fa-reddit",         brand: true,  label: "ردیت",        color: "#FF4500" },
};

function getPlatform(p: string) {
  return platformMap[p?.toLowerCase()] ?? { icon: "fa-link", brand: false, label: p ?? "لینک", color: "#888888" };
}

const avatarColors = ["#5C6BC0","#26A69A","#EC407A","#AB47BC","#42A5F5","#FF7043","#66BB6A","#FF8F00"];
function getAvatarColor(name: string) {
  let h = 0;
  for (let i = 0; i < name.length; i++) h = name.charCodeAt(i) + ((h << 5) - h);
  return avatarColors[Math.abs(h) % avatarColors.length];
}
function getInitial(name: string) { return name?.trim()?.[0] ?? "؟"; }

const searchData = entities.map(e => ({
  id: e.id,
  name: e.name,
  title: e.title ?? "",
  description: e.description ?? "",
  avatar_url: e.avatar_url,
  color: getAvatarColor(e.name),
  initial: getInitial(e.name),
  is_verified: e.is_verified,
  links: e.links.map(l => ({
    url: l.url,
    platform: l.platform,
    ...getPlatform(l.platform),
  })),
}));
---

<Layout title={category ? `${category.name} — سَقِیفَه` : "سَقِیفَه"}>
  <div class="page-shell">

    <!-- هدر -->
    <header class="page-header">
      <h1 class="page-title">{category?.name ?? "دسته‌بندی"}</h1>
    </header>

    <!-- لیست -->
    <main class="entity-list">
      {pageError && <p class="empty-state">{pageError}</p>}
      {!pageError && entities.length === 0 && <p class="empty-state">هنوز موردی ثبت نشده است.</p>}

      {entities.map((entity) => {
        const color = getAvatarColor(entity.name);
        const initial = getInitial(entity.name);
        return (
          <div class="entity-item" data-id={entity.id} data-search={entity.name.toLowerCase()}>

            <button class="entity-row" type="button" aria-expanded="false">
              <!-- آواتار -->
              <div class="avatar" style={`--av:${color}`}>
                {entity.avatar_url
                  ? <img src={entity.avatar_url} alt={entity.name} loading="lazy" />
                  : <span>{initial}</span>}
              </div>

              <!-- متا -->
              <div class="entity-meta">
                <span class="entity-name">
                  {entity.name}
                  {entity.is_verified && <i class="fa-solid fa-circle-check verified-badge"></i>}
                </span>
                {entity.title && (
                  <span class="entity-title">{entity.title}</span>
                )}
                {entity.description && (
                  <span class="entity-preview">{entity.description}</span>
                )}
              </div>

              <i class="fa-solid fa-chevron-down chevron"></i>
            </button>

            <!-- آکاردئون -->
            <div class="acc-body">
              <div class="acc-inner">
                {entity.description && (
                  <p class="acc-bio">{entity.description}</p>
                )}

                <!-- آیکون‌های شبکه اجتماعی — اسکرول افقی -->
                {entity.links.length > 0 && (
                  <div class="social-scroll-wrap">
                    <div class="social-scroll" data-scroll-id={entity.id}>
                      {entity.links.map((link) => {
                        const p = getPlatform(link.platform);
                        return (
                          <a
                            href={link.url}
                            target="_blank"
                            rel="noreferrer noopener"
                            class="social-icon-btn"
                            style={`--pc:${p.color}`}
                            title={p.label}
                            aria-label={p.label}
                          >
                            <i class={`${p.brand ? 'fa-brands' : 'fa-solid'} ${p.icon}`}></i>
                          </a>
                        );
                      })}
                    </div>
                    <!-- فلش‌های اسکرول -->
                    <button class="scroll-arrow scroll-arrow--right" type="button" data-dir="right" data-target={entity.id} aria-label="بیشتر">
                      <i class="fa-solid fa-chevron-left"></i>
                    </button>
                    <button class="scroll-arrow scroll-arrow--left" type="button" data-dir="left" data-target={entity.id} aria-label="قبلی">
                      <i class="fa-solid fa-chevron-right"></i>
                    </button>
                  </div>
                )}

                {entity.links.length === 0 && <p class="no-links">لینکی ثبت نشده است.</p>}

                <div class="acc-actions">
                  <button class="action-btn report-btn" type="button" data-name={entity.name}>
                    <i class="fa-solid fa-triangle-exclamation"></i> گزارش خرابی
                  </button>
                  <button class="action-btn share-btn" type="button"
                    data-name={entity.name} data-url={Astro.url.href}>
                    <i class="fa-solid fa-share-nodes"></i> اشتراک‌گذاری
                  </button>
                </div>
              </div>
            </div>

            <div class="divider"></div>
          </div>
        );
      })}
    </main>

    <!-- منوی پایین -->
    <nav class="bottom-nav">
      <a href="/" class="nav-item">
        <i class="fa-solid fa-house"></i>
        <span>خانه</span>
      </a>
      <button class="nav-item" id="nav-search" type="button">
        <i class="fa-solid fa-magnifying-glass"></i>
        <span>جستجو</span>
      </button>
      <button class="nav-item" id="nav-theme" type="button">
        <i class="fa-solid fa-circle-half-stroke"></i>
        <span>تم</span>
      </button>
    </nav>

    <!-- Edge Menu -->
    <div class="edge-backdrop" id="edge-backdrop"></div>
    <div class="edge-panel" id="edge-panel">
      <!-- تب بیرون‌زده -->
      <div class="edge-tab" id="edge-tab" aria-label="دسته‌بندی‌ها">
        <i class="fa-solid fa-table-cells-large"></i>
      </div>
      <!-- لیست دسته‌ها -->
      <div class="edge-cats" id="edge-cats">
        <button class="edge-arrow edge-arrow--up" id="edge-up" type="button">
          <i class="fa-solid fa-chevron-up"></i>
        </button>
        <div class="edge-cats-scroll" id="edge-scroll">
          {allCategories.map((cat) => (
            <a
              href={`/${cat.slug}`}
              class={`edge-cat-item${cat.slug === slug ? " edge-cat--active" : ""}`}
              data-name={cat.name}
              data-slug={cat.slug}
            >
              <i class={`fa-solid ${cat.icon_name || "fa-folder"}`}></i>
              <!-- حباب اسم -->
              <span class="edge-tooltip">{cat.name}</span>
            </a>
          ))}
        </div>
        <button class="edge-arrow edge-arrow--down" id="edge-down" type="button">
          <i class="fa-solid fa-chevron-down"></i>
        </button>
      </div>
    </div>

    <!-- Bottom Sheet جستجو -->
    <div class="bs-backdrop" id="bs-backdrop"></div>
    <div class="bottom-sheet" id="bottom-sheet" role="dialog" aria-modal="true">
      <div class="bs-handle"></div>
      <div class="bs-search-row">
        <i class="fa-solid fa-magnifying-glass bs-search-icon"></i>
        <input id="bs-input" type="text" placeholder="جستجو کن..." autocomplete="off" />
        <button id="bs-clear" class="bs-clear-btn" type="button" style="display:none">
          <i class="fa-solid fa-xmark"></i>
        </button>
      </div>
      <div class="bs-filters">
        <button class="bs-filter active" data-filter="all" type="button">همه</button>
        <button class="bs-filter" data-filter="entity" type="button">اشخاص</button>
        <button class="bs-filter" data-filter="platform" type="button">پلتفرم</button>
      </div>
      <div class="bs-results" id="bs-results">
        <p class="bs-hint">برای جستجو تایپ کن...</p>
      </div>
    </div>

  </div>
</Layout>

<style>
  *, *::before, *::after { box-sizing: border-box; }

  .page-shell {
    max-width: 680px;
    margin: 0 auto;
    min-height: 100vh;
    padding-bottom: 72px;
    position: relative;
  }

  /* ——— هدر ——— */
  .page-header {
    padding: 28px 20px 18px;
    background: var(--surface);
    border-bottom: 1px solid var(--border);
  }
  .page-title {
    font-size: 26px;
    font-weight: 900;
    color: var(--text-main);
    margin: 0;
    letter-spacing: 0.28em;
    text-align: center;
  }

  /* ——— لیست ——— */
  .entity-list { padding: 0; }
  .entity-item { position: relative; }

  .entity-row {
    width: 100%;
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 12px 16px;
    background: none;
    border: none;
    cursor: pointer;
    text-align: right;
    transition: background 0.12s;
  }
  .entity-row:active { background: color-mix(in srgb, var(--primary) 6%, transparent); }

  .avatar {
    width: 50px;
    height: 50px;
    border-radius: 50%;
    flex-shrink: 0;
    background: var(--av);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 20px;
    font-weight: 900;
    color: #fff;
    overflow: hidden;
  }
  .avatar img { width: 100%; height: 100%; object-fit: cover; }

  .entity-meta {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 2px;
    text-align: right;
  }

  .entity-name {
    font-size: 14px;
    font-weight: 800;
    color: var(--text-main);
    display: flex;
    align-items: center;
    gap: 5px;
  }
  .verified-badge { color: #3b9eff; font-size: 12px; }

  .entity-preview {
    font-size: 12px;
    color: var(--text-dim);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .entity-title {
    font-size: 11px;
    color: var(--primary);
    font-weight: 700;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .chevron {
    font-size: 11px;
    color: var(--text-dim);
    flex-shrink: 0;
    transition: transform 0.25s ease;
  }
  .entity-item.open .chevron { transform: rotate(180deg); }

  .divider { height: 1px; background: var(--border); margin: 0 16px; opacity: 0.4; }

  /* ——— آکاردئون ——— */
  .acc-body { display: grid; grid-template-rows: 0fr; transition: grid-template-rows 0.28s ease; }
  .entity-item.open .acc-body { grid-template-rows: 1fr; }
  .acc-inner { overflow: hidden; padding: 0 16px; }
  .entity-item.open .acc-inner { padding: 6px 16px 14px; }

  .acc-bio {
    font-size: 13px;
    color: var(--text-dim);
    line-height: 1.7;
    margin: 0 0 14px;
    padding-bottom: 12px;
    border-bottom: 1px solid var(--border);
  }

  /* ——— آیکون‌های شبکه اجتماعی ——— */
  .social-scroll-wrap {
    position: relative;
    margin-bottom: 14px;
  }

  .social-scroll {
    display: flex;
    gap: 6px;
    overflow-x: auto;
    scroll-behavior: smooth;
    padding: 4px 2px 8px;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }
  .social-scroll::-webkit-scrollbar { display: none; }

  .social-icon-btn {
    width: 42px;
    height: 42px;
    border-radius: 12px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 20px;
    color: var(--text-dim);
    background: color-mix(in srgb, var(--text-dim) 8%, transparent);
    border: 1px solid var(--border);
    text-decoration: none;
    flex-shrink: 0;
    transition: color 0.2s ease, background 0.2s ease, border-color 0.2s ease, transform 0.15s ease;
  }
  .social-icon-btn:hover {
    color: var(--pc);
    background: color-mix(in srgb, var(--pc) 12%, transparent);
    border-color: color-mix(in srgb, var(--pc) 40%, transparent);
    transform: translateY(-2px);
  }

  /* فلش‌های اسکرول */
  .scroll-arrow {
    position: absolute;
    top: 50%;
    transform: translateY(-60%);
    width: 28px;
    height: 28px;
    border-radius: 50%;
    background: var(--surface);
    border: 1px solid var(--border);
    color: var(--text-dim);
    font-size: 11px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.2s;
    box-shadow: 0 2px 8px color-mix(in srgb,#000 12%,transparent);
    z-index: 2;
  }
  .scroll-arrow.visible { opacity: 1; pointer-events: auto; }
  .scroll-arrow--right { right: 0; }
  .scroll-arrow--left  { left: 0; }

  .no-links { font-size: 12px; color: var(--text-dim); margin: 0 0 12px; }

  .acc-actions {
    display: flex;
    gap: 8px;
    border-top: 1px solid var(--border);
    padding-top: 10px;
  }
  .action-btn {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    padding: 8px;
    border-radius: 10px;
    border: 1px solid var(--border);
    background: none;
    color: var(--text-dim);
    font-size: 12px;
    font-weight: 700;
    cursor: pointer;
    font-family: inherit;
    transition: color 0.15s, border-color 0.15s;
  }
  .report-btn:hover { color: #ff5252; border-color: #ff5252; }
  .share-btn:hover  { color: var(--primary); border-color: var(--primary); }

  .empty-state { text-align: center; color: var(--text-dim); font-size: 13px; padding: 48px 16px; }

  /* ——— منوی پایین ——— */
  .bottom-nav {
    position: fixed;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 100%;
    max-width: 680px;
    display: flex;
    background: var(--surface);
    border-top: 1px solid var(--border);
    z-index: 40;
    padding-bottom: env(safe-area-inset-bottom);
  }
  .nav-item {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 4px;
    padding: 10px 0;
    color: var(--text-dim);
    text-decoration: none;
    font-size: 10px;
    font-weight: 700;
    background: none;
    border: none;
    cursor: pointer;
    font-family: inherit;
    transition: color 0.15s;
  }
  .nav-item i { font-size: 19px; }
  .nav-item:hover { color: var(--primary); }

  /* ——— Edge Menu ——— */
  .edge-backdrop {
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.3);
    backdrop-filter: blur(3px);
    -webkit-backdrop-filter: blur(3px);
    z-index: 50;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.25s ease;
  }
  .edge-backdrop.open { opacity: 1; pointer-events: auto; }

  .edge-panel {
    position: fixed;
    top: 50%;
    left: 0;
    transform: translateY(-50%) translateX(calc(-100% + 28px));
    z-index: 51;
    display: flex;
    align-items: center;
    transition: transform 0.3s cubic-bezier(0.34, 1.4, 0.64, 1);
  }
  .edge-panel.open { transform: translateY(-50%) translateX(0); }

  .edge-tab {
    width: 28px;
    height: 64px;
    background: var(--primary);
    border-radius: 0 14px 14px 0;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #fff;
    font-size: 13px;
    cursor: pointer;
    flex-shrink: 0;
    box-shadow: 3px 0 14px color-mix(in srgb, var(--primary) 45%, transparent);
    position: relative;
    z-index: 1;
  }

  .edge-cats {
    background: var(--surface);
    border: 1px solid var(--border);
    border-left: none;
    border-radius: 0 16px 16px 0;
    padding: 4px 6px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2px;
    max-height: 65vh;
    box-shadow: 4px 0 20px color-mix(in srgb, #000 15%, transparent);
    min-width: 60px;
  }

  .edge-cats-scroll {
    display: flex;
    flex-direction: column;
    gap: 4px;
    overflow-y: auto;
    scroll-behavior: smooth;
    scrollbar-width: none;
    flex: 1;
    padding: 2px 0;
  }
  .edge-cats-scroll::-webkit-scrollbar { display: none; }

  /* فلش بالا/پایین */
  .edge-arrow {
    width: 32px;
    height: 22px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: none;
    border: none;
    color: var(--text-dim);
    font-size: 11px;
    cursor: pointer;
    border-radius: 6px;
    flex-shrink: 0;
    transition: color 0.15s, opacity 0.2s;
  }
  .edge-arrow:hover { color: var(--primary); }
  .edge-arrow.hidden { opacity: 0; pointer-events: none; }

  /* آیتم دسته */
  .edge-cat-item {
    position: relative;
    width: 44px;
    height: 44px;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    color: var(--text-dim);
    font-size: 20px;
    transition: background 0.15s, color 0.15s;
    flex-shrink: 0;
  }
  .edge-cat-item:hover { background: color-mix(in srgb, var(--primary) 10%, transparent); color: var(--primary); }
  .edge-cat--active { color: var(--primary); background: color-mix(in srgb, var(--primary) 14%, transparent); }

  /* حباب اسم — سمت راست آیکون */
  .edge-tooltip {
    position: absolute;
    right: calc(100% + 10px);
    top: 50%;
    transform: translateY(-50%);
    background: var(--surface);
    border: 1px solid var(--border);
    color: var(--text-main);
    font-size: 11px;
    font-weight: 700;
    padding: 4px 10px;
    border-radius: 20px;
    white-space: nowrap;
    box-shadow: 0 2px 10px color-mix(in srgb,#000 15%,transparent);
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.2s ease;
    z-index: 10;
  }
  .edge-cat-item.show-tip .edge-tooltip { opacity: 1; }

  /* ——— Bottom Sheet ——— */
  .bs-backdrop {
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.4);
    backdrop-filter: blur(2px);
    -webkit-backdrop-filter: blur(2px);
    z-index: 60;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.25s ease;
  }
  .bs-backdrop.open { opacity: 1; pointer-events: auto; }

  .bottom-sheet {
    position: fixed;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%) translateY(100%);
    width: 100%;
    max-width: 680px;
    height: 82vh;
    background: var(--surface);
    border-radius: 22px 22px 0 0;
    border: 1px solid var(--border);
    border-bottom: none;
    z-index: 61;
    display: flex;
    flex-direction: column;
    transition: transform 0.3s cubic-bezier(0.34, 1.2, 0.64, 1);
    padding-bottom: env(safe-area-inset-bottom);
  }
  .bottom-sheet.open { transform: translateX(-50%) translateY(0); }

  .bs-handle {
    width: 40px;
    height: 4px;
    background: var(--border);
    border-radius: 4px;
    margin: 12px auto 10px;
    flex-shrink: 0;
  }

  .bs-search-row {
    display: flex;
    align-items: center;
    gap: 10px;
    margin: 0 16px 12px;
    padding: 10px 14px;
    background: color-mix(in srgb, var(--text-dim) 8%, transparent);
    border-radius: 14px;
    border: 1px solid var(--border);
    flex-shrink: 0;
  }
  .bs-search-icon { color: var(--text-dim); font-size: 14px; }
  .bs-search-row input {
    flex: 1;
    background: none;
    border: none;
    outline: none;
    font-size: 14px;
    color: var(--text-main);
    font-family: inherit;
    direction: rtl;
  }
  .bs-clear-btn { background: none; border: none; color: var(--text-dim); cursor: pointer; font-size: 13px; padding: 2px; }

  .bs-filters {
    display: flex;
    gap: 8px;
    padding: 0 16px 12px;
    flex-shrink: 0;
  }
  .bs-filter {
    padding: 6px 18px;
    border-radius: 20px;
    border: 1px solid var(--border);
    background: none;
    color: var(--text-dim);
    font-size: 12px;
    font-weight: 700;
    cursor: pointer;
    font-family: inherit;
    transition: all 0.15s;
  }
  .bs-filter.active { background: var(--primary); border-color: var(--primary); color: #fff; }

  .bs-results { flex: 1; overflow-y: auto; padding-bottom: 16px; }

  .bs-hint { text-align: center; color: var(--text-dim); font-size: 13px; padding: 32px 16px; margin: 0; }
  .bs-no-result { text-align: center; color: var(--text-dim); font-size: 13px; padding: 32px 16px; margin: 0; }
  .bs-section-title { font-size: 11px; font-weight: 800; color: var(--text-dim); padding: 10px 16px 4px; letter-spacing: 0.05em; margin: 0; }
  .bs-divider { height: 1px; background: var(--border); margin: 0 16px; opacity: 0.4; }

  .bs-entity-card {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 10px 16px;
    cursor: pointer;
    transition: background 0.12s;
  }
  .bs-entity-card:hover { background: color-mix(in srgb, var(--primary) 5%, transparent); }

  .bs-avatar {
    width: 42px;
    height: 42px;
    border-radius: 50%;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 17px;
    font-weight: 900;
    color: #fff;
    overflow: hidden;
  }
  .bs-avatar img { width: 100%; height: 100%; object-fit: cover; }

  .bs-entity-name { font-size: 13px; font-weight: 800; color: var(--text-main); display: flex; align-items: center; gap: 4px; }
  .bs-entity-sub  { font-size: 11px; color: var(--text-dim); margin-top: 2px; }

  .bs-link-card {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 10px 16px;
    text-decoration: none;
    transition: background 0.12s;
  }
  .bs-link-card:hover { background: color-mix(in srgb, var(--primary) 5%, transparent); }

  .bs-link-icon {
    width: 40px;
    height: 40px;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 18px;
    flex-shrink: 0;
  }
  .bs-link-platform { font-size: 11px; color: var(--text-dim); }
  .bs-link-name { font-size: 13px; font-weight: 800; color: var(--text-main); }
</style>

<script is:inline define:vars={{ searchData, currentSlug: slug }}>
  // ——— تم ———
  const html = document.documentElement;
  const saved = localStorage.getItem("theme");
  if (saved === "light" || saved === "dark") html.setAttribute("data-theme", saved);
  document.getElementById("nav-theme")?.addEventListener("click", () => {
    const next = html.getAttribute("data-theme") === "light" ? "dark" : "light";
    html.setAttribute("data-theme", next);
    localStorage.setItem("theme", next);
  });

  // ——— آکاردئون ———
  document.querySelectorAll(".entity-item").forEach((item) => {
    item.querySelector(".entity-row")?.addEventListener("click", () => {
      const isOpen = item.classList.contains("open");
      document.querySelectorAll(".entity-item").forEach((i) => {
        i.classList.remove("open");
        i.querySelector(".entity-row")?.setAttribute("aria-expanded", "false");
      });
      if (!isOpen) {
        item.classList.add("open");
        item.querySelector(".entity-row")?.setAttribute("aria-expanded", "true");
        // آپدیت فلش‌های اسکرول
        const id = item.getAttribute("data-id");
        setTimeout(() => updateScrollArrows(id), 300);
      }
    });
  });

  // ——— اسکرول افقی آیکون‌ها ———
  function updateScrollArrows(entityId) {
    const scroll = document.querySelector(`.social-scroll[data-scroll-id="${entityId}"]`);
    if (!scroll) return;
    const arrowR = document.querySelector(`.scroll-arrow--right[data-target="${entityId}"]`);
    const arrowL = document.querySelector(`.scroll-arrow--left[data-target="${entityId}"]`);
    if (arrowR) arrowR.classList.toggle("visible", scroll.scrollLeft < scroll.scrollWidth - scroll.clientWidth - 4);
    if (arrowL) arrowL.classList.toggle("visible", scroll.scrollLeft > 4);
  }

  document.querySelectorAll(".social-scroll").forEach((scroll) => {
    const id = scroll.getAttribute("data-scroll-id");
    scroll.addEventListener("scroll", () => updateScrollArrows(id));
  });

  document.querySelectorAll(".scroll-arrow").forEach((btn) => {
    btn.addEventListener("click", (e) => {
      e.stopPropagation();
      const id  = btn.getAttribute("data-target");
      const dir = btn.getAttribute("data-dir");
      const scroll = document.querySelector(`.social-scroll[data-scroll-id="${id}"]`);
      if (scroll) scroll.scrollBy({ left: dir === "right" ? 120 : -120, behavior: "smooth" });
    });
  });

  // ——— Edge Menu ———
  const edgePanel    = document.getElementById("edge-panel");
  const edgeBackdrop = document.getElementById("edge-backdrop");
  const edgeTab      = document.getElementById("edge-tab");
  const edgeScroll   = document.getElementById("edge-scroll");
  const edgeUp       = document.getElementById("edge-up");
  const edgeDown     = document.getElementById("edge-down");

  function openEdge()  { edgePanel?.classList.add("open"); edgeBackdrop?.classList.add("open"); updateEdgeArrows(); }
  function closeEdge() { edgePanel?.classList.remove("open"); edgeBackdrop?.classList.remove("open"); }

  edgeTab?.addEventListener("click", () => edgePanel?.classList.contains("open") ? closeEdge() : openEdge());
  edgeBackdrop?.addEventListener("click", closeEdge);

  function updateEdgeArrows() {
    if (!edgeScroll || !edgeUp || !edgeDown) return;
    edgeUp.classList.toggle("hidden",   edgeScroll.scrollTop <= 4);
    edgeDown.classList.toggle("hidden", edgeScroll.scrollTop >= edgeScroll.scrollHeight - edgeScroll.clientHeight - 4);
  }

  edgeScroll?.addEventListener("scroll", updateEdgeArrows);
  edgeUp?.addEventListener("click",   () => { edgeScroll?.scrollBy({ top: -120, behavior: "smooth" }); });
  edgeDown?.addEventListener("click", () => { edgeScroll?.scrollBy({ top:  120, behavior: "smooth" }); });

  // حباب اسم + کلیک
  document.querySelectorAll(".edge-cat-item").forEach((item) => {
    let tipTimer = null;

    function showTip() {
      item.classList.add("show-tip");
      clearTimeout(tipTimer);
      tipTimer = setTimeout(() => item.classList.remove("show-tip"), 3000);
    }

    // hover دسکتاپ
    item.addEventListener("mouseenter", showTip);
    item.addEventListener("mouseleave", () => {
      clearTimeout(tipTimer);
      tipTimer = setTimeout(() => item.classList.remove("show-tip"), 500);
    });

    item.addEventListener("click", (e) => {
      const href = item.getAttribute("href");
      const isCurrent = item.getAttribute("data-slug") === currentSlug;

      if (isCurrent) {
        e.preventDefault();
        showTip();
        // اسکرول به مرکز
        item.scrollIntoView({ behavior: "smooth", block: "center" });
        return;
      }

      // اول حباب نشون بده، بعد برو
      e.preventDefault();
      showTip();
      item.scrollIntoView({ behavior: "smooth", block: "center" });
      setTimeout(() => { window.location.href = href; }, 350);
    });
  });

  // ——— Bottom Sheet جستجو ———
  const bsBackdrop  = document.getElementById("bs-backdrop");
  const bottomSheet = document.getElementById("bottom-sheet");
  const bsInput     = document.getElementById("bs-input");
  const bsResults   = document.getElementById("bs-results");
  const bsClear     = document.getElementById("bs-clear");

  let activeFilter = "all";

  function openBS() {
    bottomSheet?.classList.add("open");
    bsBackdrop?.classList.add("open");
    setTimeout(() => bsInput?.focus(), 300);
  }
  function closeBS() {
    bottomSheet?.classList.remove("open");
    bsBackdrop?.classList.remove("open");
    if (bsInput) bsInput.value = "";
    if (bsClear) bsClear.style.display = "none";
    renderResults("");
  }

  document.getElementById("nav-search")?.addEventListener("click", openBS);
  bsBackdrop?.addEventListener("click", closeBS);

  document.querySelectorAll(".bs-filter").forEach((btn) => {
    btn.addEventListener("click", () => {
      document.querySelectorAll(".bs-filter").forEach(b => b.classList.remove("active"));
      btn.classList.add("active");
      activeFilter = btn.getAttribute("data-filter") ?? "all";
      renderResults(bsInput?.value ?? "");
    });
  });

  bsInput?.addEventListener("input", (e) => {
    const val = e.target.value;
    if (bsClear) bsClear.style.display = val ? "block" : "none";
    renderResults(val);
  });

  bsClear?.addEventListener("click", () => {
    if (bsInput) bsInput.value = "";
    bsClear.style.display = "none";
    renderResults("");
    bsInput?.focus();
  });

  function renderResults(query) {
    if (!bsResults) return;
    const q = query.trim().toLowerCase();
    if (!q) { bsResults.innerHTML = '<p class="bs-hint">برای جستجو تایپ کن...</p>'; return; }

    let entityResults = [];
    let linkResults   = [];

    if (activeFilter === "all" || activeFilter === "entity") {
      entityResults = searchData.filter(e =>
        e.name.toLowerCase().includes(q) ||
        (e.description && e.description.toLowerCase().includes(q))
      );
    }

    if (activeFilter === "all" || activeFilter === "platform") {
      searchData.forEach(entity => {
        entity.links.forEach(link => {
          if (link.label.toLowerCase().includes(q) || link.platform.toLowerCase().includes(q)) {
            linkResults.push({ ...link, entityName: entity.name, entityColor: entity.color, entityInitial: entity.initial, entityAvatar: entity.avatar_url });
          }
        });
      });
    }

    if (!entityResults.length && !linkResults.length) {
      bsResults.innerHTML = '<p class="bs-no-result">نتیجه‌ای یافت نشد.</p>';
      return;
    }

    let out = "";

    if (entityResults.length) {
      if (activeFilter === "all") out += `<p class="bs-section-title">اشخاص و موسسات</p>`;
      entityResults.forEach(e => {
        const av = e.avatar_url
          ? `<img src="${e.avatar_url}" alt="${e.name}" style="width:100%;height:100%;object-fit:cover;border-radius:50%">`
          : e.initial;
        out += `
          <div class="bs-entity-card" onclick="scrollToEntity('${e.id}')">
            <div class="bs-avatar" style="background:${e.color}">${av}</div>
            <div>
              <div class="bs-entity-name">
                ${e.name}
                ${e.is_verified ? '<i class="fa-solid fa-circle-check" style="color:#3b9eff;font-size:11px"></i>' : ''}
              </div>
              ${e.description ? `<div class="bs-entity-sub">${e.description}</div>` : ''}
            </div>
          </div>
          <div class="bs-divider"></div>`;
      });
    }

    if (linkResults.length) {
      if (activeFilter === "all") out += `<p class="bs-section-title">لینک‌ها</p>`;
      linkResults.forEach(l => {
        out += `
          <a href="${l.url}" target="_blank" rel="noreferrer noopener" class="bs-link-card">
            <div class="bs-link-icon" style="background:color-mix(in srgb,${l.color} 14%,transparent);color:${l.color}">
              <i class="${l.brand ? 'fa-brands' : 'fa-solid'} ${l.icon}"></i>
            </div>
            <div>
              <div class="bs-link-platform">${l.label}</div>
              <div class="bs-link-name">${l.entityName}</div>
            </div>
          </a>
          <div class="bs-divider"></div>`;
      });
    }

    bsResults.innerHTML = out;
  }

  window.scrollToEntity = function(id) {
    closeBS();
    setTimeout(() => {
      const target = document.querySelector(`.entity-item[data-id="${id}"]`);
      if (!target) return;
      target.scrollIntoView({ behavior: "smooth", block: "center" });
      if (!target.classList.contains("open")) {
        target.classList.add("open");
        target.querySelector(".entity-row")?.setAttribute("aria-expanded", "true");
        const entityId = target.getAttribute("data-id");
        setTimeout(() => updateScrollArrows(entityId), 300);
      }
    }, 350);
  };

  // ——— گزارش و اشتراک ———
  document.querySelectorAll(".report-btn").forEach(btn => {
    btn.addEventListener("click", () => alert(`گزارش خرابی برای «${btn.getAttribute("data-name")}» ثبت شد.`));
  });
  document.querySelectorAll(".share-btn").forEach(btn => {
    btn.addEventListener("click", async () => {
      const url = btn.getAttribute("data-url") ?? location.href;
      const name = btn.getAttribute("data-name") ?? "";
      try {
        if (navigator.share) await navigator.share({ title: name, url });
        else { await navigator.clipboard.writeText(url); alert("لینک کپی شد!"); }
      } catch {}
    });
  });
</script>