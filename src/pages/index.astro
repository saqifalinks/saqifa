<script is:inline define:vars={{ slides, slideIconMap, ctaMap, SB_URL, SB_KEY, PlatData: PLATFORMS, CatMap: categories.reduce((m,c)=>(m[c.id]=c,m),{}), platCounts: platformCounts }}>
  // تم
  const html = document.documentElement;
  const saved = localStorage.getItem("theme");
  if (saved==="light"||saved==="dark") html.setAttribute("data-theme",saved);
  function setThemeIcons(m) {
    const icon = m==="light" ? "ph:moon-bold" : "ph:sun-bold";
    document.querySelectorAll("#ln-theme .iconify, #nav-theme .iconify").forEach(el => el.setAttribute("data-icon", icon));
  }
  setThemeIcons(html.getAttribute("data-theme")||"dark");
  function toggleTheme() {
    const next = html.getAttribute("data-theme")==="light" ? "dark" : "light";
    html.setAttribute("data-theme",next); localStorage.setItem("theme",next);
    setThemeIcons(next);
  }
  document.getElementById("nav-theme")?.addEventListener("click",toggleTheme);
  document.getElementById("ln-theme")?.addEventListener("click",toggleTheme);

  // منوی موبایل
  const menuToggle=document.getElementById("menu-toggle");
  const menuClose=document.getElementById("menu-close");
  const mSidebar=document.getElementById("mobile-sidebar");
  const mBackdrop=document.getElementById("mobile-menu-backdrop");
  function openMenu()  { mSidebar?.classList.add("open"); mBackdrop?.classList.add("open"); }
  function closeMenu() { mSidebar?.classList.remove("open"); mBackdrop?.classList.remove("open"); }
  menuToggle?.addEventListener("click",openMenu);
  menuClose?.addEventListener("click",closeMenu);
  mBackdrop?.addEventListener("click",closeMenu);
  mSidebar?.querySelectorAll("a,button").forEach(el=>el.addEventListener("click",closeMenu));

  // اسلایدر مطلب روز
  let idx=0, isPaused=false, timer;
  const DURATION=5000;
  const titleEl=document.getElementById("slide-title");
  const descEl=document.getElementById("slide-desc");
  const linkEl=document.getElementById("slide-link");
  const btnTextEl=document.getElementById("btn-text");
  const iconEl=document.getElementById("slide-icon");
  const pauseIcon=document.getElementById("pause-icon");

  function updateSlide() {
    if (!slides?.length||!titleEl) return;
    const s=slides[idx];
    titleEl.textContent=s.title||"بدون عنوان";
    descEl.textContent=s.description||"";
    linkEl.href=s.url||"#";
    btnTextEl.textContent=ctaMap[s.slide_type]||"بیشتر بخوانید";
    const cur = document.getElementById("slide-icon");
    if (cur) {
      const n = document.createElement("span");
      n.className = "iconify"; n.id = "slide-icon";
      n.setAttribute("data-icon", slideIconMap[s.slide_type] || "ph:book-bold");
      n.setAttribute("data-width", "30");
      cur.replaceWith(n);
    }
    document.querySelectorAll(".line-fill").forEach((l,i)=>l.classList.toggle("active",i===idx));
  }
  function startTimer() {
    clearInterval(timer);
    if (!slides?.length) return;
    timer=setInterval(()=>{ if (!isPaused){ idx=(idx+1)%slides.length; updateSlide(); } },DURATION);
  }
  document.getElementById("next-btn")?.addEventListener("click",()=>{ if (!slides?.length) return; idx=(idx+1)%slides.length; updateSlide(); startTimer(); });
  document.getElementById("prev-btn")?.addEventListener("click",()=>{ if (!slides?.length) return; idx=(idx-1+slides.length)%slides.length; updateSlide(); startTimer(); });
  const pauseBtn=document.getElementById("pause-btn");
  const playBtn=document.getElementById("play-btn");
  function updatePlayPause() {
    if (pauseBtn) pauseBtn.style.display=isPaused?"none":"";
    if (playBtn) playBtn.style.display=isPaused?"":"none";
  }
  pauseBtn?.addEventListener("click",()=>{ isPaused=true; updatePlayPause(); });
  playBtn?.addEventListener("click",()=>{ isPaused=false; updatePlayPause(); });
  updatePlayPause();
  if (slides?.length) { updateSlide(); startTimer(); }

  // لمسی
  let tx=0;
  document.querySelector(".daily-card")?.addEventListener("touchstart",e=>{tx=e.changedTouches[0].screenX;},{passive:true});
  document.querySelector(".daily-card")?.addEventListener("touchend",e=>{
    const dx=e.changedTouches[0].screenX-tx;
    if (!slides?.length||Math.abs(dx)<50) return;
    idx=dx<0?(idx+1)%slides.length:(idx-1+slides.length)%slides.length;
    updateSlide(); startTimer();
  },{passive:true});

  // اسلایدر دسته‌ها (چیزی حذف نشد، دکمه‌ها همچنان کار میکنن)

  // شمارنده
  function animateCounter(el,target) {
    const dur=3000, start=performance.now();
    function tick(now) {
      const p=Math.min((now-start)/dur,1);
      const e=1-Math.pow(1-p,3);
      el.textContent=Math.round(e*target).toLocaleString("fa-IR");
      if (p<1) requestAnimationFrame(tick);
    }
    requestAnimationFrame(tick);
  }
  const statsSection=document.getElementById("stats-section");
  if (statsSection) {
    let counted=false;
    new IntersectionObserver(entries=>{
      if (entries[0].isIntersecting&&!counted) {
        counted=true;
        document.querySelectorAll(".stat-num").forEach(el=>animateCounter(el,parseInt(el.getAttribute("data-target")||"0")));
      }
    },{threshold:0.3}).observe(statsSection);
  }

  // جستجوی موبایل
  const msSheet=document.getElementById("ms-sheet");
  const msBackdrop=document.getElementById("ms-backdrop");
  const msInput=document.getElementById("ms-input");
  const msClear=document.getElementById("ms-clear");
  const msResults=document.getElementById("ms-results");
  let msFilter="all", msTimer=null;

  function openMS()  { msSheet?.classList.add("open"); msBackdrop?.classList.add("open"); setTimeout(()=>msInput?.focus(),300); }
  function closeMS() {
    msSheet?.classList.remove("open"); msBackdrop?.classList.remove("open");
    if (msInput) msInput.value="";
    if (msClear) msClear.style.display="none";
    if (msResults) msResults.innerHTML='<p class="ms-hint">برای جستجو تایپ کنید...</p>';
  }
  document.getElementById("nav-search")?.addEventListener("click",openMS);
  msBackdrop?.addEventListener("click",closeMS);

  document.querySelectorAll(".ms-filter").forEach(btn=>{
    btn.addEventListener("click",()=>{
      document.querySelectorAll(".ms-filter").forEach(b=>b.classList.remove("active"));
      btn.classList.add("active");
      msFilter=btn.getAttribute("data-filter")||"all";
      if (msInput?.value.trim()) doMSearch(msInput.value.trim());
    });
  });
  msInput?.addEventListener("input",e=>{
    const q=e.target.value.trim();
    if (msClear) msClear.style.display=q?"block":"none";
    clearTimeout(msTimer);
    if (!q) { if (msResults) msResults.innerHTML='<p class="ms-hint">برای جستجو تایپ کنید...</p>'; return; }
    msTimer=setTimeout(()=>doMSearch(q),350);
  });
  msClear?.addEventListener("click",()=>{
    msInput.value=""; msClear.style.display="none";
    if (msResults) msResults.innerHTML='<p class="ms-hint">برای جستجو تایپ کنید...</p>';
    msInput?.focus();
  });

  function prepQuery(s) {
    s=s.replace(/[َُِّْٰٓ]/g,'')
       .replace(/[يى]/g,'ی').replace(/[ك]/g,'ک')
       .replace(/[ة]/g,'ه').replace(/[إأٱ]/g,'ا')
       .replace(/[ؤ]/g,'و').replace(/[ئ]/g,'ی')
       .replace(/[ھ]/g,'ه').replace(/[ے]/g,'ی');
    const spaced=s.replace(/[\s\u200C\u200D\u00A0]+/g,'%');
    const tight=s.replace(/[\s\u200C\u200D\u00A0]/g,'');
    const p2=tight.length>2?tight.split('').join('%'):null;
    return [spaced,p2].filter(Boolean);
  }

  async function doMSearch(q) {
    if (!SB_URL||!SB_KEY||!msResults) return;
    const patterns=prepQuery(q);
    msResults.innerHTML='<p class="ms-hint">در حال جستجو...</p>';
    try {
      const headers={"apikey":SB_KEY,"Authorization":`Bearer ${SB_KEY}`};
      let html="";
      if (msFilter==="all"||msFilter==="entity") {
        const conds=patterns.flatMap(p=>[`name.ilike.*${encodeURIComponent(p)}*`,`title.ilike.*${encodeURIComponent(p)}*`,`description.ilike.*${encodeURIComponent(p)}*`]).join(',');
        const res=await fetch(`${SB_URL}/rest/v1/entities?or=(${conds})&select=id,name,title,description,avatar_url,category_id&limit=10`,{headers});
        const entities=await res.json();
        if (entities?.length) {
          if (msFilter==="all") html+=`<p class="ms-section-title">شخصیت‌ها و مراکز</p>`;
          entities.forEach(e=>{
            html+=`<button class="ms-entity-card" type="button" data-cat-id="${e.category_id}" data-entity-id="${e.id}"><div class="ms-entity-name">${e.name}</div></button><div class="ms-divider"></div>`;
          });
        }
      }
      if (msFilter==="platform") {
        const pConds=patterns.map(p=>`platform.ilike.*${encodeURIComponent(p)}*`).join(',');
        const res=await fetch(`${SB_URL}/rest/v1/links?or=(${pConds})&select=id,platform,url,entity_id,entities(name,category_id)&limit=10`,{headers});
        const links=await res.json();
        if (links?.length) {
          html+=`<p class="ms-section-title">پلتفرم‌ها</p>`;
          links.forEach(l=>{
            const pi=getP(l.platform);
            html+=`<a href="${l.url}" target="_blank" rel="noreferrer" class="ms-entity-card" data-url="${l.url}" style="display:flex;flex-direction:column;align-items:flex-start;gap:2px;padding:10px 16px;color:var(--text-main);text-decoration:none;width:100%"><div style="display:flex;align-items:center;gap:8px"><span class="iconify" data-icon="${pi.icon}" data-width="18" style="color:${pi.color}"></span><span style="font-size:13px;font-weight:700">${pi.label}</span></div><span style="font-size:12px;padding-right:26px;color:var(--text-muted)">${l.entities?.name??""}</span></a><div class="ms-divider"></div>`;
          });
        }
      }
      msResults.innerHTML=html||'<p class="ms-no-result">نتیجه‌ای یافت نشد.</p>';
      if (window.Iconify) window.Iconify.scan(msResults);
    } catch { msResults.innerHTML='<p class="ms-no-result">خطا در جستجو.</p>'; }
  }

  msResults?.addEventListener("click",e=>{
    const btn=e.target.closest(".ms-entity-card");
    if (!btn) return;
    const catId=btn.getAttribute("data-cat-id");
    const entityId=btn.getAttribute("data-entity-id");
    const cat=CatMap?.[catId];
    if (cat) {
      msBackdrop?.classList.remove("open");
      msSheet?.classList.remove("open");
      document.body.style.overflow="";
      if (window.innerWidth>=768) {
        switchToCategory(catId, cat.name, entityId);
      } else {
        window.location.href=`/${cat.slug}#entity-${entityId}`;
      }
    }
  });

  // جستجوی دسکتاپ
  const dsToggle=document.getElementById("ds-toggle");
  const dsBody=document.getElementById("ds-body");
  const dsInput=document.getElementById("ds-input");
  const dsClear=document.getElementById("ds-clear");
  const dsResults=document.getElementById("ds-results");
  let dsFilter="all", dsTimer=null;

  dsToggle?.addEventListener("click",()=>{
    const isOpen=dsBody?.classList.contains("open");
    dsBody?.classList.toggle("open",!isOpen);
    dsToggle?.classList.toggle("open",!isOpen);
    if (!isOpen) setTimeout(()=>dsInput?.focus(),200);
  });

  document.querySelectorAll(".ds-filter").forEach(btn=>{
    btn.addEventListener("click",()=>{
      document.querySelectorAll(".ds-filter").forEach(b=>b.classList.remove("active"));
      btn.classList.add("active");
      dsFilter=btn.getAttribute("data-filter")||"all";
      if (dsInput?.value.trim()) doDSearch(dsInput.value.trim());
    });
  });

  dsInput?.addEventListener("input",e=>{
    const q=e.target.value.trim();
    if (dsClear) dsClear.style.display=q?"block":"none";
    clearTimeout(dsTimer);
    if (!q) { dsResults.innerHTML=""; return; }
    dsTimer=setTimeout(()=>doDSearch(q),350);
  });
  dsClear?.addEventListener("click",()=>{
    dsInput.value=""; dsClear.style.display="none"; dsResults.innerHTML="";
    dsInput?.focus();
  });

  async function doDSearch(q) {
    if (!SB_URL||!SB_KEY||!dsResults) return;
    const patterns=prepQuery(q);
    dsResults.innerHTML=`<p class="ds-empty">در حال جستجو...</p>`;
    try {
      const headers={"apikey":SB_KEY,"Authorization":`Bearer ${SB_KEY}`};
      let html="";

      if (dsFilter==="all"||dsFilter==="entity") {
        const conds=patterns.flatMap(p=>[`name.ilike.*${encodeURIComponent(p)}*`,`title.ilike.*${encodeURIComponent(p)}*`,`description.ilike.*${encodeURIComponent(p)}*`]).join(',');
        const res=await fetch(`${SB_URL}/rest/v1/entities?or=(${conds})&select=id,name,title,description,avatar_url,category_id&limit=10`,{headers});
        const entities=await res.json();
        if (entities?.length) {
          if (dsFilter==="all") html+=`<p class="ds-section-title">شخصیت‌ها و مراکز</p>`;
          entities.forEach(e=>{
            html+=`<button class="ds-item" type="button" data-cat-id="${e.category_id}" data-entity-id="${e.id}"><span class="ds-item-title">${e.name}</span></button><div class="ds-divider"></div>`;
          });
        }
      }

      if (dsFilter==="platform") {
        const pConds=patterns.map(p=>`platform.ilike.*${encodeURIComponent(p)}*`).join(',');
        const res=await fetch(`${SB_URL}/rest/v1/links?or=(${pConds})&select=id,platform,url,entity_id,entities(name,category_id)&limit=10`,{headers});
        const links=await res.json();
        if (links?.length) {
          html+=`<p class="ds-section-title">پلتفرم‌ها</p>`;
          links.forEach(l=>{
            const pi=getP(l.platform);
            html+=`<a href="${l.url}" target="_blank" rel="noreferrer" class="ds-item" data-url="${l.url}" style="display:flex;flex-direction:column;align-items:flex-start;gap:2px;padding:10px 12px;border-radius:8px;color:var(--text-main);text-decoration:none;width:100%"><div style="display:flex;align-items:center;gap:8px"><span class="iconify" data-icon="${pi.icon}" data-width="18" style="color:${pi.color}"></span><span style="font-size:13px;font-weight:700">${pi.label}</span></div><span style="font-size:12px;padding-right:26px;color:var(--text-muted)">${l.entities?.name??""}</span></a><div class="ds-divider"></div>`;
          });
        }
      }

      dsResults.innerHTML=html||`<p class="ds-empty">نتیجه‌ای یافت نشد.</p>`;
      if (window.Iconify) window.Iconify.scan(dsResults);
    } catch { dsResults.innerHTML=`<p class="ds-empty">خطا در جستجو.</p>`; }
  }

  dsResults?.addEventListener("click",e=>{
    const btn=e.target.closest(".ds-item");
    if (!btn) return;
    const catId=btn.getAttribute("data-cat-id");
    const entityId=btn.getAttribute("data-entity-id");
    const cat=CatMap?.[catId];
    if (cat) {
      dsBody?.classList.remove("open");
      dsToggle?.classList.remove("open");
      switchToCategory(catId, cat.name, entityId);
    }
  });

  const AV_COLORS=["#5C6BC0","#26A69A","#EC407A","#AB47BC","#42A5F5","#FF7043","#66BB6A","#FF8F00"];
  function getAVColor(name) { let h=0; for (let i=0;i<name.length;i++) h=name.charCodeAt(i)+((h<<5)-h); return AV_COLORS[Math.abs(h)%AV_COLORS.length]; }

  // منوی راست — بارگذاری دسته
  const homeView=document.getElementById("home-view");
  const catView=document.getElementById("cat-view");
  const catTitle=document.getElementById("cat-view-title");
  const entityList=document.getElementById("entity-list");
  const catBack=document.getElementById("cat-back");

  function getP(p) {
    const d=PlatData?.[p];
    if (d) return {icon:d.icon,color:d.color,label:p};
    if (PlatData) {
      for (const [,v] of Object.entries(PlatData)) {
        const key=(p??"").toLowerCase().trim();
        if (key.includes(v.name_en)||v.name_en.includes(key)) return {icon:v.icon,color:v.color,label:p};
      }
    }
    return {icon:"ph:link-bold",color:"#888",label:p??"لینک"};
  }

  function renderEntity(entity) {
    const color=getAVColor(entity.name);
    const initial=entity.name?.trim()?.[0]??"؟";
    const links=(entity.links??[]).sort((a,b)=>a.display_order-b.display_order);
    const av=entity.avatar_url?`<img src="${entity.avatar_url}" alt="" style="width:100%;height:100%;object-fit:cover">`
      :initial;
    const linksHtml=links.map(l=>{const p=getP(l.platform);return`<a href="${l.url}" target="_blank" rel="noreferrer" class="social-icon-btn" style="--pc:${p.color}" title="${p.label}"><span class="iconify" data-icon="${p.icon}" data-width="22"></span></a>`;}).join("")||`<p class="no-links">لینکی ثبت نشده.</p>`;
    const div=document.createElement("div");
    div.className="entity-item"; div.setAttribute("data-id",entity.id);
    div.innerHTML=`<button class="entity-row" type="button" aria-expanded="false"><div class="avatar" style="--av:${color}">${av}</div><div class="entity-meta"><span class="entity-name">${entity.name}${entity.verification_type==='blue'?'<span class="iconify" data-icon="ph:seal-check-fill" data-width="14" style="color:#3b9eff"></span>':entity.verification_type==='gold'?'<span class="iconify" data-icon="ph:seal-check-fill" data-width="14" style="color:#d4af37"></span>':''}</span>${entity.title?`<span class="entity-title-text">${entity.title}</span>`:''}</div><span class="iconify chevron-icon" data-icon="ph:caret-down-bold" data-width="13"></span></button><div class="acc-body"><div class="acc-inner">${entity.description?`<p class="acc-bio">${entity.description}</p>`:''}<div class="social-scroll-wrap"><div class="social-scroll" data-sid="${entity.id}">${linksHtml}</div><button class="scroll-arr scroll-arr--r" data-dir="right" data-sid="${entity.id}" type="button"><span class="iconify" data-icon="ph:caret-left-bold" data-width="11"></span></button><button class="scroll-arr scroll-arr--l" data-dir="left" data-sid="${entity.id}" type="button"><span class="iconify" data-icon="ph:caret-right-bold" data-width="11"></span></button></div><div class="acc-actions"><button class="action-btn report-btn" data-name="${entity.name}" type="button"><span class="iconify" data-icon="ph:warning-bold" data-width="13"></span> گزارش خرابی لینک</button><button class="action-btn share-btn" data-name="${entity.name}" data-url="${location.href}" type="button"><span class="iconify" data-icon="ph:share-network-bold" data-width="13"></span> اشتراک‌گذاری</button></div></div></div>`;

    div.querySelector(".entity-row")?.addEventListener("click",()=>{
      const isOpen=div.classList.contains("open");
      document.querySelectorAll(".entity-item").forEach(i=>{i.classList.remove("open");i.querySelector(".entity-row")?.setAttribute("aria-expanded","false");});
      if (!isOpen) { requestAnimationFrame(()=>{requestAnimationFrame(()=>{div.classList.add("open");div.querySelector(".entity-row")?.setAttribute("aria-expanded","true");setTimeout(()=>updateSA(entity.id),350);});}); }
    });
    div.querySelectorAll(".scroll-arr").forEach(btn=>{
      btn.addEventListener("click",e=>{e.stopPropagation();const sid=btn.getAttribute("data-sid");const dir=btn.getAttribute("data-dir");const s=div.querySelector(`.social-scroll[data-sid="${sid}"]`);if(s)s.scrollBy({left:dir==="right"?120:-120,behavior:"smooth"});});
    });
    div.querySelector(".social-scroll")?.addEventListener("scroll",()=>updateSA(entity.id));
    div.querySelector(".report-btn")?.addEventListener("click",async()=>{try{await fetch(`${SB_URL}/rest/v1/link_suggestions`,{method:"POST",headers:{"Content-Type":"application/json","apikey":SB_KEY,"Authorization":`Bearer ${SB_KEY}`},body:JSON.stringify({target_name:entity.name,target_url:location.href,notes:"گزارش خرابی لینک"})});alert(`گزارش خرابی لینک برای «${entity.name}» ثبت شد.`);}catch{alert("خطا در ثبت گزارش.");}});
    div.querySelector(".share-btn")?.addEventListener("click",async e=>{try{const text=buildShareText(entity);if(navigator.share)await navigator.share({title:entity.name,text});else{await navigator.clipboard.writeText(text);showFeedback(e);}}catch{}});
    return div;
  }

  function updateSA(id) {
    const s=document.querySelector(`.social-scroll[data-sid="${id}"]`);
    if (!s) return;
    const hasOverflow=s.scrollWidth>s.clientWidth+2;
    document.querySelector(`.scroll-arr--r[data-sid="${id}"]`)?.classList.toggle("visible",hasOverflow);
    document.querySelector(`.scroll-arr--l[data-sid="${id}"]`)?.classList.toggle("visible",hasOverflow);
  }

  function buildShareText(entity) {
    const enc = p => {
      const labels = { telegram: "تلگرام", instagram: "اینستاگرام", youtube: "یوتیوب",
        website: "وبسایت", tiktok: "تیک‌تاک", twitter: "توییتر", x: "ایکس",
        aparat: "آپارات", linkedin: "لینکدین", whatsapp: "واتساپ", facebook: "فیسبوک",
        spotify: "اسپاتیفای", soundcloud: "ساندکلاد", discord: "دیسکورد", threads: "تردز",
        email: "ایمیل", blog: "وبلاگ" };
      return labels[p] || p;
    };
    let t = entity.title ? `${entity.name} — ${entity.title}` : entity.name;
    if (entity.description) t += `\n${entity.description.replace(/<[^>]*>/g,"").trim().slice(0,200)}`;
    if (entity.links?.length) {
      t += `\n\n🔗 لینک‌ها:`;
      entity.links.forEach(l => { t += `\n• ${enc(l.platform)}: ${l.url}`; });
    }
    t += `\n\n✦ سقیفه\nدریچه‌ای به منابع تاریخی و پژوهشی\n🌐 saqifah.com`;
    return t;
  }

  function showFeedback(e) {
    const el = document.createElement("div");
    el.className = "copy-feedback";
    el.innerText = "متن کپی و آماده ارسال شد";
    el.style.left = `${e.clientX}px`;
    el.style.top = `${e.clientY - 40}px`;
    document.body.appendChild(el);
    setTimeout(() => { el.classList.add("fade-out"); setTimeout(() => el.remove(), 400); }, 1000);
  }

  let activeFilterOptId = null;

  async function fetchEntities(catId, focusEntityId) {
    try {
      const headers = { "apikey": SB_KEY, "Authorization": `Bearer ${SB_KEY}` };
      let url = `${SB_URL}/rest/v1/entities?category_id=eq.${catId}&select=id,name,title,description,avatar_url,verification_type,links(id,platform,url,display_order)&order=created_at.asc`;
      if (activeFilterOptId) {
        const evRes = await fetch(`${SB_URL}/rest/v1/entity_filter_values?filter_option_id=eq.${activeFilterOptId}&select=entity_id`, { headers });
        const evData = await evRes.json();
        const ids = (evData ?? []).map(r => r.entity_id).filter(Boolean);
        if (ids.length === 0) {
          if (entityList) entityList.innerHTML = '<p class="empty-state">نتیجه‌ای یافت نشد.</p>';
          return;
        }
        url = `${SB_URL}/rest/v1/entities?category_id=eq.${catId}&id=in.(${ids.join(",")})&select=id,name,title,description,avatar_url,verification_type,links(id,platform,url,display_order)&order=created_at.asc`;
      }
      const res = await fetch(url, { headers });
      const data = await res.json();
      if (entityList) {
        entityList.innerHTML = "";
        if (!data?.length) { entityList.innerHTML = '<p class="empty-state">هنوز موردی ثبت نشده است.</p>'; }
        else { data.forEach(e => entityList.appendChild(renderEntity(e))); if (window.Iconify) window.Iconify.scan(entityList); }
        if (focusEntityId) {
          setTimeout(() => {
            const el = entityList.querySelector(`.entity-item[data-id="${focusEntityId}"]`);
            if (el) {
              el.querySelector(".entity-row")?.click();
              setTimeout(() => el.scrollIntoView({ behavior: "smooth", block: "center" }), 400);
            }
          }, 50);
        }
      }
    } catch { if (entityList) entityList.innerHTML = '<p class="empty-state">خطا در دریافت اطلاعات.</p>'; }
  }

  async function fetchAndRenderFilters(catId) {
    const filterBar = document.getElementById("cat-filter-bar");
    if (!filterBar) return;
    try {
      const headers = { "apikey": SB_KEY, "Authorization": `Bearer ${SB_KEY}` };
      const cfRes = await fetch(`${SB_URL}/rest/v1/category_filters?category_id=eq.${catId}&is_active=eq.true&select=filter_id`, { headers });
      const cfData = await cfRes.json();
      if (!cfData?.length) { filterBar.innerHTML = ""; return; }
      const fIds = cfData.map(r => r.filter_id).join(",");
      const [fRes, foRes] = await Promise.all([
        fetch(`${SB_URL}/rest/v1/filters?id=in.(${fIds})&select=id,name,slug&order=display_order.asc`, { headers }),
        fetch(`${SB_URL}/rest/v1/filter_options?filter_id=in.(${fIds})&select=id,filter_id,value,display_order&order=display_order.asc`, { headers }),
      ]);
      const [fData, foData] = await Promise.all([fRes.json(), foRes.json()]);
      let html = '<div class="filter-bar">';
      for (const f of (fData ?? [])) {
        const opts = (foData ?? []).filter(o => o.filter_id === f.id);
        html += `<div class="filter-group"><span class="filter-label">${f.name}</span><div class="fscroll-wrap">`;
        html += `<div class="filter-options" data-fscroll="${f.slug}">`;
        html += `<button class="filter-chip active" data-opt-id="">همه</button>`;
        for (const o of opts) {
          html += `<button class="filter-chip" data-opt-id="${o.id}">${o.value}</button>`;
        }
        html += `</div>`;
        html += `<button class="fscroll-arr fscroll-arr--r" data-fdir="right" data-fscroll="${f.slug}" type="button" aria-label="بعدی"><span class="iconify" data-icon="ph:caret-left" data-width="11" data-height="11"></span></button>`;
        html += `<button class="fscroll-arr fscroll-arr--l" data-fdir="left" data-fscroll="${f.slug}" type="button" aria-label="قبلی"><span class="iconify" data-icon="ph:caret-right" data-width="11" data-height="11"></span></button>`;
        html += `</div></div>`;
      }
      html += '</div>';
      filterBar.innerHTML = html;
      filterBar.querySelectorAll(".filter-options").forEach(s => {
        const fslug = s.getAttribute("data-fscroll");
        if (!fslug) return;
        const fn = () => {
          const hasOverflow = s.scrollWidth > s.clientWidth + 2;
          filterBar.querySelector(`.fscroll-arr--r[data-fscroll="${fslug}"]`)?.classList.toggle("visible", hasOverflow);
          filterBar.querySelector(`.fscroll-arr--l[data-fscroll="${fslug}"]`)?.classList.toggle("visible", hasOverflow);
        };
        s.addEventListener("scroll", fn);
        fn();
      });
      filterBar.querySelectorAll(".fscroll-arr").forEach(btn => {
        btn.addEventListener("click", () => {
          const fslug = btn.getAttribute("data-fscroll");
          const dir = btn.getAttribute("data-fdir");
          const s = filterBar.querySelector(`.filter-options[data-fscroll="${fslug}"]`);
          if (s) s.scrollBy({ left: dir === "right" ? 120 : -120, behavior: "smooth" });
        });
      });
      filterBar.querySelectorAll(".filter-chip").forEach(chip => {
        chip.addEventListener("click", () => {
          filterBar.querySelectorAll(".filter-chip").forEach(c => c.classList.remove("active"));
          chip.classList.add("active");
          chip.scrollIntoView({ behavior: "smooth", inline: "center", block: "nearest" });
          activeFilterOptId = chip.getAttribute("data-opt-id") || null;
          if (entityList) entityList.innerHTML = `<div class="loading-state"><span class="iconify spin" data-icon="ph:spinner-bold" data-width="28" style="color:var(--primary)"></span></div>`;
          fetchEntities(catId);
        });
      });
    } catch { filterBar.innerHTML = ""; }
  }

  async function loadCategory(catId,catName,focusEntityId) {
    if (!SB_URL||!SB_KEY) return;
    activeFilterOptId = null;
    if (homeView) homeView.style.display="none";
    if (catView)  catView.style.display="block";
    if (catTitle) catTitle.textContent=catName;
    const filterBar = document.getElementById("cat-filter-bar");
    if (filterBar) filterBar.innerHTML = "";
    if (entityList) entityList.innerHTML=`<div class="loading-state"><span class="iconify spin" data-icon="ph:spinner-bold" data-width="28" style="color:var(--primary)"></span></div>`;
    await Promise.all([
      fetchEntities(catId, focusEntityId),
      fetchAndRenderFilters(catId),
    ]);
  }

  function switchToCategory(catId, catName, focusEntityId) {
    document.querySelectorAll(".rn-cat-btn").forEach(b=>b.classList.remove("active"));
    const activeBtn=document.querySelector(`.rn-cat-btn[data-cat-id="${catId}"]`);
    if (activeBtn) activeBtn.classList.add("active");
    document.getElementById("home-view").style.display="none";
    document.getElementById("cat-view").style.display="block";
    if (catTitle) catTitle.textContent=catName;
    loadCategory(catId, catName, focusEntityId);
  }

  // اسکرول به هدر دسته بعد از بارگذاری (دسکتاپ)
  function scrollCatHeader() {
    const h=document.querySelector(".cat-view-header");
    if (h) h.scrollIntoView({behavior:"smooth",block:"start"});
  }

  document.querySelectorAll(".rn-cat-btn").forEach(btn=>{
    btn.addEventListener("click",()=>{
      const catId=btn.getAttribute("data-cat-id");
      if (catId) switchToCategory(catId,btn.getAttribute("data-cat-name"));
    });
  });

  // منوی آبشاری زبان
  const langGroup = document.querySelector(".rn-cat-group");
  const langDropdown = document.querySelector(".group-dropdown");
  if (langGroup && langDropdown) {
    document.body.appendChild(langDropdown);
    let hideTimer = null;
    function showLangDropdown() {
      if (hideTimer) clearTimeout(hideTimer);
      const rect = langGroup.querySelector(".group-trigger").getBoundingClientRect();
      langDropdown.style.right = (window.innerWidth - rect.left) + "px";
      langDropdown.style.visibility = "hidden";
      langDropdown.style.display = "flex";
      const dropH = langDropdown.offsetHeight;
      let top = rect.top;
      if (top + dropH > window.innerHeight - 8) {
        top = Math.max(8, window.innerHeight - dropH - 8);
      }
      langDropdown.style.top = top + "px";
      langDropdown.style.visibility = "visible";
    }
    function hideLangDropdown() {
      hideTimer = setTimeout(() => { langDropdown.style.display = "none"; }, 300);
    }
    langGroup.addEventListener("mouseenter", showLangDropdown);
    langGroup.addEventListener("mouseleave", hideLangDropdown);
    langDropdown.addEventListener("mouseenter", showLangDropdown);
    langDropdown.addEventListener("mouseleave", hideLangDropdown);
  }

  // دسته‌های اسلایدر دسکتاپ
  document.querySelectorAll(".desktop-cats .cat-card, .desktop-lang-cats .cat-card").forEach(btn=>{
    btn.addEventListener("click",()=>{
      switchToCategory(btn.getAttribute("data-cat-id"),btn.getAttribute("data-cat-name"));
    });
  });

  // فلش‌های اسلایدر
  const catSlider = document.querySelector(".cats-slider");
  if (catSlider) {
    document.querySelector(".slider-arrow-next")?.addEventListener("click", () => {
      catSlider.scrollBy({ left: catSlider.offsetWidth * 0.8, behavior: "smooth" });
    });
    document.querySelector(".slider-arrow-prev")?.addEventListener("click", () => {
      catSlider.scrollBy({ left: -(catSlider.offsetWidth * 0.8), behavior: "smooth" });
    });
  }

  catBack?.addEventListener("click",()=>{
    catView.style.display="none";
    homeView.style.display="block";
    document.querySelectorAll(".rn-cat-btn").forEach(b=>b.classList.remove("active"));
  });

  // پاپ‌آپ زبان موبایل
  const langBtn = document.getElementById("mob-lang-btn");
  const langOverlay = document.getElementById("mob-lang-overlay");
  const langClose = document.getElementById("mob-lang-close");
  if (langBtn && langOverlay) {
    function openLang() { langOverlay.style.display = "flex"; langBtn.setAttribute("aria-expanded", "true"); }
    function closeLang() { langOverlay.style.display = "none"; langBtn.setAttribute("aria-expanded", "false"); }
    langBtn.addEventListener("click", openLang);
    langClose?.addEventListener("click", closeLang);
    langOverlay.addEventListener("click", e => { if (e.target === langOverlay) closeLang(); });
  }

  // مودال‌ها
  const overlay=document.getElementById("modal-overlay");
  function openM(id) {
    if(!overlay)return; overlay.style.display="flex";
    document.querySelectorAll(".modal-card").forEach(m=>m.style.display="none");
    const modal=document.getElementById(id); if(modal)modal.style.display="block";
  }
  document.querySelectorAll(".open-about-trigger").forEach(el=>el.addEventListener("click",()=>openM("modal-about")));
  document.querySelectorAll(".open-contact-trigger").forEach(el=>el.addEventListener("click",()=>openM("modal-contact")));
  document.querySelectorAll(".open-add-trigger").forEach(el=>el.addEventListener("click",()=>openM("modal-add")));

  document.querySelectorAll(".close-modal").forEach(b=>b.addEventListener("click",()=>overlay.style.display="none"));
  overlay?.addEventListener("click",e=>{if(e.target===overlay)overlay.style.display="none";});
</script>
