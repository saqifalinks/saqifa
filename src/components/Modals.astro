---
import { SUGGEST_PLATFORMS } from "../lib/config";
const SB_URL = import.meta.env.SUPABASE_URL;
const SB_KEY = import.meta.env.SUPABASE_ANON_KEY;
---

<div id="modal-overlay" class="modal-overlay">
  <div id="modal-about" class="modal-card">
    <div class="modal-body">
      <h3 class="modal-title-center">درباره سقیفه</h3>
      <p class="text-justify">
        «سَقيفه» مرجعی تخصصی برای گردآوری و معرفی لینک‌های برگزیده‌ی محتوای اهل‌سنت است؛ پلی آرام و منظم میان جست‌وجو و رسیدن، برای آنان که می‌خواهند در میان انبوه محتوا، مسیر خود را روشن‌تر و بی‌هیاهوتر بیابند.
      </p>
      <p class="text-justify">
        در «سَقيفه»، فعالیت‌های علمی و دینی علما، اندیشمندان، مدارس و مراکز دینی ایران و افغانستان گردآوری شده و مهم‌ترین بسترهای ارتباطی همچون اینستاگرام، تلگرام، یوتیوب و پلتفرم‌های معتبر دیگر به شکلی ساده و منظم ارائه شده با این هدف که رسیدن به محتوای اصیل دینی، سریع‌تر، آسان‌تر و همراه با آرامش باشد.
      </p>
      <div class="about-socials">
        <a href="https://instagram.com/saqifeh" class="about-social-link" target="_blank" rel="noreferrer" aria-label="اینستاگرام">
          <span class="iconify" data-icon="simple-icons:instagram" data-width="22"></span>
        </a>
        <a href="https://t.me/saqifeh" class="about-social-link" target="_blank" rel="noreferrer" aria-label="تلگرام">
          <span class="iconify" data-icon="simple-icons:telegram" data-width="22"></span>
        </a>
        <a href="https://tiktok.com/@saqifeh" class="about-social-link" target="_blank" rel="noreferrer" aria-label="تیک تاک">
          <span class="iconify" data-icon="simple-icons:tiktok" data-width="22"></span>
        </a>
      </div>
      <button class="btn-close-bottom close-modal">بستن</button>
    </div>
  </div>

  <div id="modal-contact" class="modal-card">
    <div class="modal-head">
      <h3>تماس با ما</h3>
      <button class="close-modal-icon close-modal" type="button">
        <span class="iconify" data-icon="ph:x-bold" data-width="16"></span>
      </button>
    </div>
    <div class="modal-body">
      <div class="contact-links">
        <a href="#" class="contact-item">
          <span class="iconify" data-icon="simple-icons:telegram" data-width="18"></span> پشتیبانی تلگرام <span style="font-size:10px;color:var(--text-dim)">(هنوز فعال نشده)</span>
        </a>
        <a href="mailto:saqifa.links@gmail.com" class="contact-item">
          <span class="iconify" data-icon="ph:envelope-bold" data-width="18"></span> saqifa.links@gmail.com
        </a>
      </div>
    </div>
  </div>

  <div id="modal-add" class="modal-card">
    <div class="modal-head">
      <h3>پیشنهاد لینک جدید</h3>
      <button class="close-modal-icon close-modal" type="button">
        <span class="iconify" data-icon="ph:x-bold" data-width="16"></span>
      </button>
    </div>
    <div class="modal-body">
      <form id="suggest-form" class="suggest-form">
        <label class="input-label">نام شما (اختیاری):</label>
        <input type="text" id="suggest-sender" placeholder="مثلاً: عمر محمدی..." class="modal-input" />

        <label class="input-label">عنوان مجموعه / شخصیت:</label>
        <input type="text" id="suggest-target" placeholder="مثلاً: کتابخانه دیجیتال..." class="modal-input" required />

        <label class="input-label">لینک‌ها:</label>
        <div class="platform-scroll">
          <div class="platform-list">
            {SUGGEST_PLATFORMS.map(p => (
              <div class="platform-row">
                <div class="pr-icon" style={`--pc:${p.color}`}>
                  <span class="iconify" data-icon={p.icon} data-width="16"></span>
                </div>
                <span class="pr-label">{p.label}</span>
                <input type="url" id={`link-${p.id}`} placeholder={`https://${p.id}.com/...`} dir="ltr" class="pr-input" />
              </div>
            ))}
          </div>
        </div>

        <label class="input-label">توضیحات بیشتر:</label>
        <textarea id="suggest-notes" placeholder="توضیحات کوتاه..." class="modal-input" rows="2"></textarea>

        <button type="submit" class="btn-submit" id="suggest-submit">
          <span class="btn-submit-text">ارسال جهت بررسی</span>
          <span class="iconify spin" data-icon="ph:spinner-bold" data-width="16" style="display:none"></span>
        </button>
        <p id="suggest-msg" class="suggest-msg"></p>
      </form>
    </div>
  </div>
</div>

<script is:inline define:vars={{ SB_URL, SB_KEY, PlatIds: SUGGEST_PLATFORMS.map(p => p.id) }}>
  const form = document.getElementById("suggest-form");
  if (form && SB_URL && SB_KEY) {
    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      const submitBtn = document.getElementById("suggest-submit");
      const btnText = submitBtn?.querySelector(".btn-submit-text");
      const spinner = submitBtn?.querySelector(".spin");
      const msg = document.getElementById("suggest-msg");
      if (submitBtn) submitBtn.disabled = true;
      if (btnText) btnText.textContent = "در حال ارسال...";
      if (spinner) spinner.style.display = "inline-block";
      if (msg) msg.textContent = "";

      const sender = document.getElementById("suggest-sender")?.value ?? "";
      const target = document.getElementById("suggest-target")?.value ?? "";
      const notes = document.getElementById("suggest-notes")?.value ?? "";
      const platforms = PlatIds;
      const errors = [];

      for (const p of platforms) {
        const input = document.getElementById(`link-${p}`);
        const url = input?.value?.trim();
        if (!url) continue;
        try {
          const res = await fetch(`${SB_URL}/rest/v1/link_suggestions`, {
            method: "POST",
            headers: {
              "apikey": SB_KEY,
              "Authorization": `Bearer ${SB_KEY}`,
              "Content-Type": "application/json",
              "Prefer": "return=minimal",
            },
            body: JSON.stringify({
              sender_name: sender,
              target_name: target,
              target_url: url,
              notes: `پلتفرم: ${p} — ${notes}`,
            }),
          });
          if (!res.ok) errors.push(p);
        } catch { errors.push(p); }
      }

      if (msg) {
        if (errors.length === 0) {
          msg.textContent = "✅ پیشنهاد شما با موفقیت ثبت شد.";
          msg.style.color = "var(--success)";
          form.reset();
        } else {
          msg.textContent = `❌ خطا در ارسال ${errors.join(", ")}.`;
          msg.style.color = "#ff5252";
        }
      }

      if (submitBtn) submitBtn.disabled = false;
      if (btnText) btnText.textContent = "ارسال جهت بررسی";
      if (spinner) spinner.style.display = "none";
    });
  }
</script>

<style>
  .modal-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.7);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    display: none;
    align-items: center;
    justify-content: center;
    z-index: 4000;
    padding: 20px;
  }

  .modal-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 28px;
    width: 100%;
    max-width: 450px;
    display: none;
    flex-direction: column;
    max-height: 90vh;
    box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
    animation: modalIn 0.3s ease-out;
  }

  @keyframes modalIn {
    from { opacity: 0; transform: scale(0.95) translateY(10px); }
    to { opacity: 1; transform: scale(1) translateY(0); }
  }

  .modal-head {
    padding: 15px 25px;
    border-bottom: 1px solid var(--border);
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .modal-head h3 { font-size: 16px; color: var(--primary); margin: 0; font-weight: 800; }

  .close-modal-icon {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: color-mix(in srgb, var(--text-dim) 10%, transparent);
    border: 1px solid var(--border);
    color: var(--text-dim);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: color 0.15s, background 0.15s;
  }
  .close-modal-icon:hover { color: var(--text-main); background: color-mix(in srgb, var(--text-dim) 20%, transparent); }

  .modal-body { padding: 20px 25px; overflow-y: auto; }

  .modal-title-center { text-align: center; color: var(--primary); margin-bottom: 15px; font-size: 18px; }
  .text-justify { text-align: justify; text-justify: inter-word; line-height: 1.8; margin-bottom: 20px; color: var(--text-dim); font-size: 13px; }
  .btn-close-bottom { width: 100%; background: color-mix(in srgb, var(--text-dim) 10%, transparent); border: 1px solid var(--border); padding: 12px; border-radius: 12px; color: var(--text-main); font-weight: 700; cursor: pointer; font-family: inherit; transition: background 0.15s; }
  .btn-close-bottom:hover { background: color-mix(in srgb, var(--text-dim) 20%, transparent); }

  .suggest-form { display: flex; flex-direction: column; }
  .input-label { display: block; font-size: 12px; font-weight: 700; margin-bottom: 6px; color: var(--text-dim); letter-spacing: 0.02em; }

  .modal-input {
    width: 100%;
    background: color-mix(in srgb, var(--bg) 40%, transparent);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 10px 14px;
    margin-bottom: 14px;
    color: var(--text-main);
    font-family: inherit;
    font-size: 13px;
    transition: border-color 0.15s;
  }
  .modal-input:focus { outline: none; border-color: var(--primary); }

  /* ناحیه پلتفرم‌ها */
  .platform-scroll {
    background: color-mix(in srgb, var(--bg) 25%, transparent);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 10px;
    max-height: 260px;
    overflow-y: auto;
    margin-bottom: 16px;
    scrollbar-width: thin;
  }
  .platform-scroll::-webkit-scrollbar { width: 4px; }
  .platform-scroll::-webkit-scrollbar-thumb { background: var(--primary); border-radius: 4px; }

  .platform-list { display: flex; flex-direction: column; gap: 6px; }

  .platform-row {
    display: flex;
    align-items: center;
    gap: 10px;
    background: color-mix(in srgb, var(--surface) 70%, transparent);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 6px 10px;
    transition: border-color 0.15s, background 0.15s;
  }
  .platform-row:focus-within { border-color: var(--pc, var(--primary)); background: color-mix(in srgb, var(--surface) 90%, transparent); }

  .pr-icon {
    width: 32px; height: 32px; border-radius: 10px;
    display: flex; align-items: center; justify-content: center;
    background: color-mix(in srgb, var(--pc) 12%, transparent);
    color: var(--pc);
    flex-shrink: 0;
  }
  .pr-label {
    font-size: 11px; font-weight: 700; color: var(--text-main);
    white-space: nowrap; min-width: 55px;
  }
  .pr-input {
    flex: 1; min-width: 0;
    background: transparent; border: none;
    color: var(--text-dim); font-size: 12px; direction: ltr;
    padding: 4px 0; outline: none;
  }
  .pr-input:focus { color: var(--text-main); }
  .pr-input::placeholder { color: color-mix(in srgb, var(--text-dim) 50%, transparent); }

  .btn-submit {
    width: 100%;
    background: var(--primary);
    color: #ffffff;
    border: none;
    padding: 14px;
    border-radius: 14px;
    font-weight: 800;
    cursor: pointer;
    font-family: inherit;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    font-size: 13px;
    transition: opacity 0.15s, transform 0.15s;
  }
  .btn-submit:hover { opacity: 0.9; transform: translateY(-1px); }
  .btn-submit:disabled { opacity: 0.5; cursor: not-allowed; transform: none; }

  .suggest-msg { text-align: center; font-size: 12px; margin-top: 10px; min-height: 24px; font-weight: 600; }

  @keyframes spin { to { transform: rotate(360deg); } }
  .spin { animation: spin 1s linear infinite; }

  .contact-item {
    display: flex;
    align-items: center;
    gap: 12px;
    background: color-mix(in srgb, var(--surface) 50%, transparent);
    border: 1px solid var(--border);
    padding: 15px;
    border-radius: 15px;
    text-decoration: none;
    color: var(--text-main);
    margin-bottom: 10px;
    font-weight: 700;
    transition: border-color 0.15s;
  }
  .contact-item:hover { border-color: var(--primary); }

  .about-socials {
    display: flex;
    justify-content: center;
    gap: 16px;
    margin: 16px 0 20px;
  }
  .about-social-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: color-mix(in srgb, var(--text-dim) 8%, transparent);
    border: 1px solid var(--border);
    color: var(--text-dim);
    text-decoration: none;
    transition: color 0.2s, background 0.2s, border-color 0.2s, transform 0.15s;
  }
  .about-social-link:hover {
    transform: translateY(-2px);
  }
  .about-social-link[aria-label="اینستاگرام"]:hover {
    color: #e4405f;
    background: color-mix(in srgb, #e4405f 12%, transparent);
    border-color: #e4405f;
  }
  .about-social-link[aria-label="تلگرام"]:hover {
    color: #0088cc;
    background: color-mix(in srgb, #0088cc 12%, transparent);
    border-color: #0088cc;
  }
  .about-social-link[aria-label="تیک تاک"]:hover {
    color: #000000;
    background: color-mix(in srgb, #000000 12%, transparent);
    border-color: #000000;
  }
</style>
