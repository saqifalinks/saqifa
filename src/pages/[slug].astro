---
export const prerender = false;

import Layout from '../layouts/Layout.astro';
import { isSupabaseConfigured, supabase } from "../lib/supabase";
import { getCategoryIcon, getPlatformInfo, normalizeUrl, getPlatformSvg } from "../lib/config";
import { PLATFORM_SVG } from "../lib/svg-paths";

const { slug } = Astro.params;
const SB_URL = import.meta.env.SUPABASE_URL;
const SB_KEY = import.meta.env.SUPABASE_ANON_KEY;

type Category = { id: string; name: string; slug: string; icon_name: string; };
type Link     = { id: string; platform: string; url: string; display_order: number; };
type Entity   = { id: string; name: string; title: string | null; description: string | null; avatar_url: string | null; verification_type: string | null; links: Link[]; };
type FilterOpt = { id: number; value: string; display_order: number; };
type CatFilter = { id: number; name: string; slug: string; options: FilterOpt[]; };

let category: Category | null = null;
let entities: Entity[] = [];
let allEntities: Entity[] = [];
let allCategories: Category[] = [];
let filtersList: CatFilter[] = [];
let activeFilters: Record<string, string> = {};
let pageError = "";

if (isSupabaseConfigured && supabase) {
  try {
    const [{ data: catData, error: catError }, { data: allCats }] = await Promise.all([
      supabase.from("categories").select("id,name,slug,icon_name").eq("slug", slug).single(),
      supabase.from("categories").select("id,name,slug,icon_name").order("display_order", { ascending: true }),
    ]);

    allCategories = (allCats ?? []) as Category[];

    if (catError || !catData) {
      pageError = "دسته‌بندی یافت نشد.";
    } else {
      category = catData as Category;

      // دریافت فیلترهای فعال این دسته
      const { data: cfData } = await supabase
        .from("category_filters")
        .select("filter_id")
        .eq("category_id", category.id)
        .eq("is_active", true);

      if (cfData && cfData.length > 0) {
        const fIds = cfData.map((r: any) => r.filter_id);
        const [{ data: fData }, { data: foData }] = await Promise.all([
          supabase.from("filters").select("id, name, slug").in("id", fIds).order("display_order", { ascending: true }),
          supabase.from("filter_options").select("id, filter_id, value, display_order").in("filter_id", fIds).order("display_order", { ascending: true }),
        ]);
        filtersList = (fData ?? []).map((f: any) => ({
          id: f.id, name: f.name, slug: f.slug,
          options: (foData ?? []).filter((o: any) => o.filter_id === f.id).sort((a: FilterOpt, b: FilterOpt) => a.display_order - b.display_order),
        }));
      }

      // پارس فیلترهای فعال از URL
      for (const f of filtersList) {
        const val = Astro.url.searchParams.get(f.slug);
        if (val) activeFilters[f.slug] = val;
      }

      // دریافت همه entityهای این دسته
      const { data: rawEntities, error: entitiesError } = await supabase
        .from("entities")
        .select("id,name,title,description,avatar_url,verification_type,links(id,platform,url,display_order)")
        .eq("category_id", category.id)
        .order("created_at", { ascending: true });

      if (entitiesError) {
        pageError = "خطا در دریافت اطلاعات.";
      } else {
        const sorted = (rawEntities ?? []).map((e: any) => ({
          ...e,
          links: (e.links ?? []).sort((a: Link, b: Link) => a.display_order - b.display_order),
        }));
        allEntities = sorted;
        // فیلتر کردن برای نمایش (اگر فیلتری فعال باشه)
        const filterKeys = Object.keys(activeFilters);
        if (filterKeys.length > 0) {
          const matchedFilters = filtersList.filter(f => activeFilters[f.slug]);
          const queries = matchedFilters.map(mf => {
            const optId = parseInt(activeFilters[mf.slug]);
            return supabase
              .from("entity_filter_values")
              .select("entity_id")
              .eq("filter_option_id", optId);
          });
          const results = await Promise.all(queries);
          const allFilteredIds = results.map(({ data }) =>
            (data ?? []).map((r: any) => r.entity_id)
          );

          // اشتراک بین فیلترها (AND)
          let finalIds: string[] = allFilteredIds[0] ?? [];
          for (let i = 1; i < allFilteredIds.length; i++) {
            finalIds = finalIds.filter(id => allFilteredIds[i].includes(id));
          }
          if (finalIds.length > 0) {
            const idSet = new Set(finalIds);
            entities = sorted.filter(e => idSet.has(e.id));
          } else {
            entities = [];
          }
        } else {
          entities = sorted;
        }
      }
    }
  } catch {
    pageError = "خطا در ارتباط با دیتابیس.";
  }
}

const avatarColors = ["#5C6BC0","#26A69A","#EC407A","#AB47BC","#42A5F5","#FF7043","#66BB6A","#FF8F00"];
function getAvatarColor(name: string) {
  let h = 0;
  for (let i = 0; i < name.length; i++) h = name.charCodeAt(i) + ((h << 5) - h);
  return avatarColors[Math.abs(h) % avatarColors.length];
}
function getInitial(name: string) { return name?.trim()?.[0] ?? "؟"; }

const searchData = allEntities.map(e => ({
  id: e.id,
  name: e.name,
  title: e.title ?? "",
  description: e.description ?? "",
  avatar_url: e.avatar_url,
  color: getAvatarColor(e.name),
  initial: getInitial(e.name),
  verification_type: e.verification_type,
  links: e.links.map(l => ({ url: normalizeUrl(l.url, l.platform), platform: l.platform, ...getPlatformInfo(l.platform) })),
  filterValues: (e.entity_filter_values ?? []).map(efv => efv.filter_options?.value ?? '').filter(Boolean),
}));
---

<Layout title={category ? `${category.name} — سَقِیفَه` : "سَقِیفَه"}>
  <div class="page-shell">

    <!-- هدر -->
    <div class="page-sticky">
    <header class="page-header">
      <h1 class="page-title">{category?.name ?? "دسته‌بندی"}</h1>
    </header>

    <!-- فیلترها -->
    {filtersList.length > 0 && (
      <div class="filter-bar">
        {filtersList.map(f => (
          <div class="filter-group">
            <span class="filter-label">{f.name}</span>
            <div class="fscroll-wrap">
              <div class="filter-options" data-fscroll={f.slug}>
                <a href={`/${slug}`}
                  class={`filter-chip${!activeFilters[f.slug] ? " active" : ""}`}
                  data-filter-slug={f.slug}
                  data-option-id="">
                  همه
                </a>
                {f.options.map(o => (
                  <a href={`/${slug}?${f.slug}=${o.id}`}
                    class={`filter-chip${activeFilters[f.slug] === String(o.id) ? " active" : ""}`}
                    data-filter-slug={f.slug}
                    data-option-id={o.id}>
                    {o.value}
                  </a>
                ))}
              </div>
              <button class="fscroll-arr fscroll-arr--r" data-fdir="right" data-fscroll={f.slug} type="button" aria-label="بعدی">
                <span class="iconify" data-icon="ph:caret-left" data-width="11" data-height="11"></span>
              </button>
              <button class="fscroll-arr fscroll-arr--l" data-fdir="left" data-fscroll={f.slug} type="button" aria-label="قبلی">
                <span class="iconify" data-icon="ph:caret-right" data-width="11" data-height="11"></span>
              </button>
            </div>
          </div>
        ))}
      </div>
    )}
    </div>

    <!-- لیست -->
    <section class="entity-list" id="entity-list" role="list">
      {pageError && <p class="empty-state">{pageError}</p>}
      {!pageError && entities.length === 0 && <p class="empty-state">هنوز موردی ثبت نشده است.</p>}

      {entities.map((entity) => {
        const color = getAvatarColor(entity.name);
        const initial = getInitial(entity.name);
        return (
          <div class="entity-item glass-card" data-id={entity.id} data-search={entity.name.toLowerCase()}>

            <button class="entity-row" type="button" aria-expanded="false">
              <div class="avatar" style={`--av:${color};width:50px;height:50px`}>
                {entity.avatar_url
                  ? <img src={entity.avatar_url} alt={entity.name} width="50" height="50" loading="lazy" />
                  : <span>{initial}</span>}
              </div>

              <div class="entity-meta">
                <h3 class="entity-name">
                  {entity.name}
                  {entity.verification_type === 'blue' && (
                    <span class="iconify verified-badge" data-icon="ph:seal-check-fill" data-width="15" data-height="15" style="color:#3b9eff"></span>
                  )}
                  {entity.verification_type === 'gold' && (
                    <span class="iconify verified-badge" data-icon="ph:seal-check-fill" data-width="15" data-height="15" style="color:#d4af37"></span>
                  )}
                </h3>
                {entity.title && <span class="entity-title">{entity.title}</span>}
              </div>

              <span class="iconify chevron" data-icon="ph:caret-down" data-width="14" data-height="14"></span>
            </button>

            <!-- آکاردئون -->
            <div class="acc-body">
              <div class="acc-inner">
                {entity.description && <p class="acc-bio">{entity.description}</p>}

                {entity.links.length > 0 && (
                  <div class="social-scroll-wrap">
                    <div class="social-scroll" data-scroll-id={entity.id}>
                      {entity.links.map((link) => {
                        const p = getPlatformInfo(link.platform);
                        const sv = getPlatformSvg(link.platform);
                        return (
                          <a href={normalizeUrl(link.url, link.platform)} target="_blank" rel="noreferrer noopener"
                            class="social-icon-btn" style={`--pc:${p.color}`}
                            title={p.label} aria-label={p.label}>
                            <svg class="pi" width="22" height="22" viewBox={sv.vb} fill="currentColor" role="img" aria-label={p.label}><path d={sv.d}/></svg>
                          </a>
                        );
                      })}
                    </div>
                    <button class="scroll-arr scroll-arr--r" type="button" data-dir="right" data-target={entity.id} aria-label="بعدی">
                      <span class="iconify" data-icon="ph:caret-left" data-width="11" data-height="11"></span>
                    </button>
                    <button class="scroll-arr scroll-arr--l" type="button" data-dir="left" data-target={entity.id} aria-label="قبلی">
                      <span class="iconify" data-icon="ph:caret-right" data-width="11" data-height="11"></span>
                    </button>
                  </div>
                )}

                {entity.links.length === 0 && <p class="no-links">لینکی ثبت نشده است.</p>}

                <div class="acc-actions">
                  <button class="action-btn report-btn" type="button" data-name={entity.name}>
                    <span class="iconify" data-icon="ph:warning" data-width="14" data-height="14"></span>
                    گزارش خرابی
                  </button>
                  <button class="action-btn share-btn" type="button"
                    data-entity={JSON.stringify({name:entity.name,title:entity.title,description:entity.description,links:entity.links.map(l=>({platform:l.platform,url:normalizeUrl(l.url,l.platform)}))})}>
                    <span class="iconify" data-icon="ph:share-network" data-width="14" data-height="14"></span>
                    اشتراک‌گذاری
                  </button>
                </div>
              </div>
            </div>
          </div>
        );
      })}
    </section>

    <!-- منوی پایین -->
    <nav class="bottom-nav">
      <a href="/" class="nav-item">
        <span class="iconify" data-icon="ph:house" data-width="22" data-height="22"></span>
        <span>خانه</span>
      </a>
      <button class="nav-item" id="nav-search" type="button">
        <span class="iconify" data-icon="ph:magnifying-glass" data-width="22" data-height="22"></span>
        <span>جستجو</span>
      </button>
      <button class="nav-item" id="nav-theme" type="button">
        <span class="iconify" data-icon="ph:sun-bold" data-width="22" data-height="22"></span>
        <span>تم</span>
      </button>
    </nav>

    <!-- Edge Menu -->
    <div class="edge-backdrop" id="edge-backdrop"></div>
    <div class="edge-panel" id="edge-panel">
      <div class="edge-tab" id="edge-tab">
        <span class="edge-tab-text">دسته‌ها</span>
      </div>
      <div class="edge-cats" id="edge-cats">
        <button class="edge-arrow" id="edge-up" type="button">
          <span class="iconify" data-icon="ph:caret-up" data-width="12" data-height="12"></span>
        </button>
        <div class="edge-scroll" id="edge-scroll">
          {allCategories.map((cat) => (
            <a href={`/${cat.slug}`}
              class={`edge-cat${cat.slug === slug ? " edge-cat--active" : ""}`}
              data-slug={cat.slug} data-name={cat.name}>
              <span class="edge-label">{cat.name}</span>
            </a>
          ))}
        </div>
        <button class="edge-arrow" id="edge-down" type="button">
          <span class="iconify" data-icon="ph:caret-down" data-width="12" data-height="12"></span>
        </button>
      </div>
    </div>

    <!-- Bottom Sheet جستجو -->
    <div class="bs-backdrop" id="bs-backdrop"></div>
    <div class="bottom-sheet" id="bottom-sheet">
      <div class="bs-top-bar">
        <button class="bs-close-btn" id="bs-close-btn" type="button">
          <span class="iconify" data-icon="ph:x" data-width="18" data-height="18"></span>
        </button>
        <div class="bs-handle"></div>
      </div>
      <div class="bs-search-row">
        <span class="iconify" data-icon="ph:magnifying-glass" data-width="16" data-height="16" style="color:var(--text-dim)"></span>
        <input id="bs-input" type="text" placeholder="جستجو کن..." autocomplete="off" aria-label="جستجو" />
        <button id="bs-clear" class="bs-clear-btn" type="button" style="display:none">
          <span class="iconify" data-icon="ph:x" data-width="14" data-height="14"></span>
        </button>
      </div>
      <div class="bs-filters">
        <button class="bs-filter active" data-filter="all" type="button">همه</button>
        <button class="bs-filter" data-filter="entity" type="button">اشخاص</button>
        <button class="bs-filter" data-filter="platform" type="button">پلتفرم</button>
      </div>
      <div class="bs-results" id="bs-results">
        <p class="bs-hint">برای جستجو تایپ کن...</p>
      </div>
    </div>

    <!-- دکمه برگشت به بالا -->
    <button class="scroll-to-top" id="scroll-to-top" type="button" aria-label="برگشت به بالا">
      <span class="iconify" data-icon="ph:arrow-up-bold" data-width="18" data-height="18"></span>
    </button>
    </div>
</Layout>

<style is:global>
  *, *::before, *::after { box-sizing: border-box; }

  .page-shell {
    max-width: 680px;
    margin: 0 auto;
    padding-bottom: 72px;
  }

  /* ——— هدر چسبنده + فیلتر ——— */
  .page-sticky {
    position: sticky;
    top: 0;
    z-index: 20;
    background: color-mix(in srgb, var(--surface) 85%, transparent);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border);
  }
  .page-header {
    padding: 28px 20px 18px;
  }
  .page-title {
    font-size: 24px;
    font-weight: 900;
    color: var(--text-main);
    margin: 0;
    letter-spacing: 0.28em;
    text-align: center;
  }

  /* ——— لیست ——— */
  .entity-list {
    display: flex;
    flex-direction: column;
    gap: 10px;
    padding: 14px 14px 0;
  }

  .entity-item { position: relative; }

  .entity-row {
    width: 100%;
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 12px 14px;
    background: none;
    border: none;
    cursor: pointer;
    text-align: right;
    transition: background 0.12s;
  }
  .entity-row:active { background: color-mix(in srgb, var(--primary) 6%, transparent); }

  .avatar {
    width: 50px;
    height: 50px;
    border-radius: 50%;
    flex-shrink: 0;
    background: var(--av);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 20px;
    font-weight: 900;
    color: #fff;
    overflow: hidden;
    border: 2px solid color-mix(in srgb, var(--av) 40%, transparent);
  }
  .avatar img { width: 100%; height: 100%; object-fit: cover; }

  .entity-meta {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 2px;
    text-align: right;
  }

  .entity-name {
    font-size: 14px;
    font-weight: 800;
    color: var(--text-main);
    display: flex;
    align-items: center;
    gap: 4px;
  }

  .verified-badge { color: #3b9eff; }

  .entity-title {
    font-size: 11px;
    font-weight: 700;
    color: #068f8f;
  }
  :global(html[data-theme="dark"]) .entity-title { color: #0bc6c6; }
  :global(html[data-theme="light"]) .entity-title { color: #006060; }

  .chevron {
    color: var(--text-dim);
    flex-shrink: 0;
    transition: transform 0.25s;
  }
  .entity-item.open .chevron { transform: rotate(180deg); }

  /* ——— آکاردئون ——— */
  .acc-body { display: grid; grid-template-rows: 0fr; transition: grid-template-rows 0.28s ease; }
  .entity-item.open .acc-body { grid-template-rows: 1fr; }
  .acc-inner { overflow: hidden; padding: 0 14px; }
  .entity-item.open .acc-inner { padding: 0 14px 14px; }

  .acc-bio {
    font-size: 13px;
    color: var(--text-dim);
    line-height: 1.7;
    margin: 0 0 12px;
    padding-bottom: 10px;
    border-bottom: 1px solid var(--border);
  }

  /* آیکون‌های شبکه اجتماعی */
  .social-scroll-wrap { position: relative; margin-bottom: 12px; }

  .social-scroll {
    display: flex;
    gap: 8px;
    overflow-x: auto;
    scroll-behavior: smooth;
    padding: 4px 2px 8px;
    scrollbar-width: none;
  }
  .social-scroll::-webkit-scrollbar { display: none; }

  .social-icon-btn {
    width: 44px;
    height: 44px;
    border-radius: 12px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--text-dim);
    background: color-mix(in srgb, var(--text-dim) 8%, transparent);
    border: 1px solid var(--border);
    text-decoration: none;
    flex-shrink: 0;
    transition: color 0.2s, background 0.2s, border-color 0.2s, transform 0.15s;
  }
  .social-icon-btn:hover {
    color: var(--pc);
    background: color-mix(in srgb, var(--pc) 12%, transparent);
    border-color: color-mix(in srgb, var(--pc) 40%, transparent);
    transform: translateY(-2px);
  }

  .scroll-arr {
    position: absolute;
    top: 50%;
    transform: translateY(-65%);
    width: 26px;
    height: 26px;
    border-radius: 50%;
    background: var(--surface);
    border: 1px solid var(--border);
    color: var(--text-dim);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.2s;
    box-shadow: 0 2px 8px color-mix(in srgb,#000 12%,transparent);
    z-index: 2;
  }
  .scroll-arr.visible { opacity: 1; pointer-events: auto; }
  .scroll-arr--r { right: -24px; }
  .scroll-arr--l { left: -24px; }

  .no-links { font-size: 12px; color: var(--text-dim); margin: 0 0 12px; }

  .acc-actions {
    display: flex;
    gap: 8px;
    border-top: 1px solid var(--border);
    padding-top: 10px;
  }

  .action-btn {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    padding: 8px;
    border-radius: 10px;
    border: 1px solid var(--border);
    background: none;
    color: var(--text-dim);
    font-size: 12px;
    font-weight: 700;
    cursor: pointer;
    font-family: inherit;
    transition: color 0.15s, border-color 0.15s;
  }
  .report-btn:hover { color: #ff5252; border-color: #ff5252; }
  .share-btn:hover  { color: var(--primary); border-color: var(--primary); }

  .empty-state { text-align: center; color: var(--text-dim); font-size: 13px; padding: 48px 16px; }

  /* ——— فیلترها ——— */
  .filter-bar {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    padding: 12px 14px 10px;
  }
  .filter-group {
    display: flex;
    flex-direction: column;
    gap: 4px;
    min-width: 0;
    width: 100%;
  }
  .filter-label {
    font-size: 11px;
    font-weight: 800;
    color: var(--text-dim);
  }
  .fscroll-wrap {
    position: relative;
    display: flex;
    align-items: center;
    min-width: 0;
    width: 100%;
  }
  .filter-options {
    display: flex;
    gap: 6px;
    overflow-x: auto;
    scroll-behavior: smooth;
    flex-wrap: nowrap;
    padding: 2px 0;
    min-width: 0;
    flex: 1;
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
  .filter-options::-webkit-scrollbar { display: none; }
  .fscroll-arr {
    position: absolute; top: 50%; transform: translateY(-50%);
    width: 22px; height: 22px; border-radius: 50%;
    background: var(--surface); border: 1px solid var(--border);
    color: var(--text-dim); display: flex; align-items: center; justify-content: center;
    cursor: pointer; z-index: 2; opacity: 0; pointer-events: none;
    transition: opacity 0.2s;
  }
  .fscroll-arr.visible { opacity: 1; pointer-events: auto; }
  .fscroll-arr:hover { color: var(--primary); border-color: var(--primary); }
  .fscroll-arr--r { right: -12px; }
  .fscroll-arr--l { left: -12px; }
  .filter-chip {
    display: inline-block;
    padding: 5px 14px;
    border-radius: 16px;
    font-size: 12px;
    font-weight: 700;
    text-decoration: none;
    white-space: nowrap;
    color: var(--text-dim);
    background: color-mix(in srgb, var(--text-dim) 8%, transparent);
    border: 1px solid var(--border);
    transition: all 0.15s;
    cursor: pointer;
  }
  .filter-chip:hover {
    color: var(--primary);
    border-color: var(--primary);
  }
  .filter-chip.active {
    background: var(--primary);
    border-color: var(--primary);
    color: #fff;
  }
  :global(html[data-theme="dark"]) .filter-chip.active { background: #0ab3b3; border-color: #0ab3b3; }

  /* ——— منوی پایین ——— */
  .bottom-nav {
    position: fixed;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 100%;
    max-width: 680px;
    display: flex;
    background: var(--surface);
    border-top: 1px solid var(--border);
    z-index: 40;
    padding-bottom: env(safe-area-inset-bottom);
  }

  .nav-item {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 3px;
    padding: 9px 0;
    color: var(--text-dim);
    text-decoration: none;
    font-size: 10px;
    font-weight: 700;
    background: none;
    border: none;
    cursor: pointer;
    font-family: inherit;
    transition: color 0.15s;
  }
  .nav-item:hover { color: var(--primary); }

  /* ——— Edge Menu ——— */
  .edge-backdrop {
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.3);
    backdrop-filter: blur(3px);
    z-index: 50;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.25s;
  }
  .edge-backdrop.open { opacity: 1; pointer-events: auto; }

  .edge-panel {
    position: fixed;
    top: 50%;
    left: 0;
    transform: translateY(-50%) translateX(calc(-100% + 28px));
    z-index: 51;
    display: flex;
    align-items: center;
    transition: transform 0.3s cubic-bezier(0.34,1.4,0.64,1);
  }
  .edge-panel.open { transform: translateY(-50%) translateX(0); }

  .edge-tab {
    width: 28px;
    height: 110px;
    background: var(--primary);
    border-radius: 0 14px 14px 0;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #fff;
    cursor: pointer;
    flex-shrink: 0;
    box-shadow: 3px 0 14px color-mix(in srgb,var(--primary) 45%,transparent);
  }
  .edge-tab-text {
    writing-mode: vertical-rl; font-size: 12px; font-weight: 700;
    user-select: none;
  }
  @media (min-width: 769px) {
    .edge-panel, .edge-backdrop { display: none !important; }
  }

  .edge-cats {
    background: color-mix(in srgb, var(--surface) 90%, transparent);
    backdrop-filter: blur(12px);
    border: 1px solid var(--border);
    border-left: none;
    border-radius: 0 16px 16px 0;
    padding: 4px 6px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2px;
    max-height: 65vh;
    min-width: 64px;
    box-shadow: 4px 0 20px color-mix(in srgb,#000 15%,transparent);
  }

  .edge-scroll {
    display: flex;
    flex-direction: column;
    gap: 4px;
    overflow-y: auto;
    scroll-behavior: smooth;
    scrollbar-width: none;
    flex: 1;
  }
  .edge-scroll::-webkit-scrollbar { display: none; }

  .edge-arrow {
    width: 32px;
    height: 20px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: none;
    border: none;
    color: var(--text-dim);
    cursor: pointer;
    border-radius: 6px;
    flex-shrink: 0;
    transition: color 0.15s, opacity 0.2s;
  }
  .edge-arrow:hover { color: var(--primary); }
  .edge-arrow.hidden { opacity: 0; pointer-events: none; }

  .edge-cat {
    display: flex;
    align-items: center;
    padding: 6px 12px;
    border-radius: 10px;
    text-decoration: none;
    color: var(--text-dim);
    transition: background 0.15s, color 0.15s;
    flex-shrink: 0;
    font-size: 12px;
    font-weight: 800;
    white-space: nowrap;
  }
  .edge-cat:hover { background: color-mix(in srgb,var(--primary) 10%,transparent); color: var(--primary); }
  .edge-cat--active { color: var(--primary); background: color-mix(in srgb,var(--primary) 14%,transparent); }

  /* ——— Bottom Sheet ——— */
  .bs-backdrop {
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.4);
    backdrop-filter: blur(2px);
    z-index: 60;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.25s;
  }
  .bs-backdrop.open { opacity: 1; pointer-events: auto; }

  .bottom-sheet {
    position: fixed;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%) translateY(100%);
    width: 100%;
    max-width: 680px;
    height: 82vh;
    background: var(--surface);
    border-radius: 22px 22px 0 0;
    border: 1px solid var(--border);
    border-bottom: none;
    z-index: 61;
    display: flex;
    flex-direction: column;
    transition: transform 0.3s cubic-bezier(0.34,1.2,0.64,1);
    padding-bottom: env(safe-area-inset-bottom);
  }
  .bottom-sheet.open { transform: translateX(-50%) translateY(0); }

  .bs-top-bar { display: flex; align-items: center; padding: 12px 16px 0; flex-shrink: 0; }
  .bs-handle { width: 40px; height: 4px; background: var(--border); border-radius: 4px; margin: 0 auto; flex-shrink: 0; }

  .bs-close-btn {
    width: 32px; height: 32px; border-radius: 50%;
    background: color-mix(in srgb,var(--text-dim) 10%,transparent);
    border: none; color: var(--text-dim); cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
  }

  .bs-search-row {
    display: flex;
    align-items: center;
    gap: 10px;
    margin: 0 16px 12px;
    padding: 10px 14px;
    background: color-mix(in srgb,var(--text-dim) 8%,transparent);
    border-radius: 14px;
    border: 1px solid var(--border);
    flex-shrink: 0;
  }

  .bs-search-row input {
    flex: 1;
    background: none;
    border: none;
    outline: none;
    font-size: 14px;
    color: var(--text-main);
    font-family: inherit;
    direction: rtl;
  }

  .bs-clear-btn { background: none; border: none; color: var(--text-dim); cursor: pointer; padding: 2px; }

  .bs-filters { display: flex; gap: 8px; padding: 0 16px 12px; flex-shrink: 0; }

  .bs-filter {
    padding: 6px 18px;
    border-radius: 20px;
    border: 1px solid var(--border);
    background: none;
    color: var(--text-dim);
    font-size: 12px;
    font-weight: 700;
    cursor: pointer;
    font-family: inherit;
    transition: all 0.15s;
  }
  .bs-filter.active { background: var(--primary); border-color: var(--primary); color: #fff; }

  .bs-results { flex: 1; overflow-y: auto; padding-bottom: 16px; }
  .bs-hint, .bs-no-result { text-align: center; color: var(--text-dim); font-size: 13px; padding: 32px 16px; margin: 0; }
  .bs-section-title { font-size: 11px; font-weight: 800; color: var(--text-dim); padding: 10px 16px 4px; margin: 0; }
  .bs-divider { height: 1px; background: var(--border); margin: 0 16px; opacity: 0.4; }

  .bs-entity-card {
    display: flex; align-items: center; gap: 12px; padding: 12px 16px; min-height: 44px;
    cursor: pointer; transition: background 0.12s; border-radius: 12px; width: 100%;
    border: none; background: none; font-family: inherit; font-size: inherit; text-align: inherit;
  }
  .bs-entity-card:hover { background: color-mix(in srgb,var(--primary) 5%,transparent); }
  .bs-entity-name { font-size: 13px; font-weight: 800; }

  .bs-link-card {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 10px 16px;
    text-decoration: none;
    transition: background 0.12s;
  }
  .bs-link-card:hover { background: color-mix(in srgb,var(--primary) 5%,transparent); }

  .bs-link-icon {
    width: 40px;
    height: 40px;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 18px;
    flex-shrink: 0;
  }

  .bs-link-platform { font-size: 11px; color: var(--text-dim); }
  .bs-link-name { font-size: 13px; font-weight: 800; color: var(--text-main); }

  .copy-feedback {
    position: fixed; z-index: 9999; background: var(--primary); color: #fff;
    padding: 8px 16px; border-radius: 8px; font-size: 13px; pointer-events: none;
    transition: opacity 0.4s; white-space: nowrap;
  }
  .copy-feedback.fade-out { opacity: 0; }
  .scroll-to-top {
    position: fixed; bottom: 90px; left: 16px;
    width: 44px; height: 44px; border-radius: 50%;
    background: var(--primary); color: #fff; border: none;
    box-shadow: 0 4px 14px rgba(0,0,0,0.3);
    cursor: pointer; z-index: 100;
    display: flex; align-items: center; justify-content: center;
    opacity: 0; transform: translateY(12px); pointer-events: none;
    transition: opacity 0.25s, transform 0.25s;
  }
  .scroll-to-top.visible {
    opacity: 1; transform: translateY(0); pointer-events: auto;
  }
  .scroll-to-top:hover { filter: brightness(1.15); }
  @media (min-width: 769px) {
    .scroll-to-top { bottom: 32px; left: 32px; }
  }
</style>

<script is:inline define:vars={{ searchData, currentSlug: slug, SB_URL, SB_KEY, categoryId: category?.id ?? '', PLATFORM_SVG }}>
  // تم
  const html = document.documentElement;
  const saved = localStorage.getItem("theme");
  if (saved === "light" || saved === "dark") html.setAttribute("data-theme", saved);
  function setThemeIcon(m) {
    const icon = m === "light" ? "ph:moon-bold" : "ph:sun-bold";
    const el = document.querySelector("#nav-theme .iconify");
    if (el) el.setAttribute("data-icon", icon);
  }
  setThemeIcon(html.getAttribute("data-theme") || "dark");
  document.getElementById("nav-theme")?.addEventListener("click", () => {
    const next = html.getAttribute("data-theme") === "light" ? "dark" : "light";
    html.setAttribute("data-theme", next);
    localStorage.setItem("theme", next);
    setThemeIcon(next);
  });

  // آکاردئون (delegation)
  document.getElementById("entity-list")?.addEventListener("click", e => {
    const row = e.target.closest(".entity-row");
    if (!row) return;
    const item = row.closest(".entity-item");
    if (!item) return;
    const isOpen = item.classList.contains("open");
    document.querySelectorAll(".entity-item").forEach(i => {
      i.classList.remove("open");
      i.querySelector(".entity-row")?.setAttribute("aria-expanded", "false");
    });
    if (!isOpen) {
      requestAnimationFrame(() => {
        requestAnimationFrame(() => {
          item.classList.add("open");
          item.querySelector(".entity-row")?.setAttribute("aria-expanded", "true");
          if (window.Iconify) window.Iconify.scan(item);
          setTimeout(() => updateScrollArrows(item.getAttribute("data-id")), 300);
        });
      });
    }
  });

  // اسکرول افقی
  function updateScrollArrows(id) {
    const s = document.querySelector(`.social-scroll[data-scroll-id="${id}"]`);
    if (!s) return;
    const hasOverflow = s.scrollWidth > s.clientWidth + 2;
    document.querySelector(`.scroll-arr--r[data-target="${id}"]`)?.classList.toggle("visible", hasOverflow);
    document.querySelector(`.scroll-arr--l[data-target="${id}"]`)?.classList.toggle("visible", hasOverflow);
  }

  // اسکرول افقی — دکمه‌ها (delegation)
  document.getElementById("entity-list")?.addEventListener("click", e => {
    const btn = e.target.closest(".scroll-arr");
    if (!btn) return;
    e.stopPropagation();
    const id = btn.getAttribute("data-target");
    const dir = btn.getAttribute("data-dir");
    const s = document.querySelector(`.social-scroll[data-scroll-id="${id}"]`);
    if (s) s.scrollBy({ left: dir === "right" ? 120 : -120, behavior: "smooth" });
  });
  // اسکرول افقی — اسکرول (نیاز به بایند مستقیم)
  function bindSocialScrolls() {
    document.querySelectorAll(".social-scroll:not(._bound-ss)").forEach(s => {
      s.classList.add("_bound-ss");
      s.addEventListener("scroll", () => updateScrollArrows(s.getAttribute("data-scroll-id")));
    });
  }
  bindSocialScrolls();

  // اسکرول فیلتر
  function updateFScroll(fslug) {
    const s = document.querySelector(`.filter-options[data-fscroll="${fslug}"]`);
    if (!s) return;
    const hasOverflow = s.scrollWidth > s.clientWidth + 2;
    document.querySelector(`.fscroll-arr--r[data-fscroll="${fslug}"]`)?.classList.toggle("visible", hasOverflow);
    document.querySelector(`.fscroll-arr--l[data-fscroll="${fslug}"]`)?.classList.toggle("visible", hasOverflow);
  }
  document.querySelectorAll(".filter-options").forEach(s => {
    const fslug = s.getAttribute("data-fscroll");
    s.addEventListener("scroll", () => updateFScroll(fslug));
    updateFScroll(fslug);
  });
  document.querySelectorAll(".fscroll-arr").forEach(btn => {
    btn.addEventListener("click", e => {
      const fslug = btn.getAttribute("data-fscroll");
      const dir = btn.getAttribute("data-fdir");
      const s = document.querySelector(`.filter-options[data-fscroll="${fslug}"]`);
      if (s) s.scrollBy({ left: dir === "right" ? 120 : -120, behavior: "smooth" });
    });
  });

  // اسکرول افقی فیلتر با چرخ موس
  document.querySelectorAll(".filter-options").forEach(el=>{
    el.addEventListener("wheel",e=>{
      e.preventDefault();
      el.scrollLeft += e.deltaY;
    },{passive:false});
  });

  // اسکرول به چیپ فعال
  const activeChip = document.querySelector(".filter-chip.active");
  if (activeChip) {
    setTimeout(() => activeChip.scrollIntoView({ behavior: "smooth", inline: "center", block: "nearest" }), 150);
  }

  // Edge Menu
  const edgePanel = document.getElementById("edge-panel");
  const edgeBackdrop = document.getElementById("edge-backdrop");
  const edgeScroll = document.getElementById("edge-scroll");
  const edgeUp = document.getElementById("edge-up");
  const edgeDown = document.getElementById("edge-down");

  function lockBody(lock){document.documentElement.style.overflow=lock?"hidden":""}
  function openEdge()  { edgePanel?.classList.add("open"); edgeBackdrop?.classList.add("open"); updateEdgeArrows(); lockBody(true); }
  function closeEdge() { edgePanel?.classList.remove("open"); edgeBackdrop?.classList.remove("open"); lockBody(false); }

  document.getElementById("edge-tab")?.addEventListener("click", () =>
    edgePanel?.classList.contains("open") ? closeEdge() : openEdge()
  );
  edgeBackdrop?.addEventListener("click", closeEdge);

  function updateEdgeArrows() {
    if (!edgeScroll) return;
    edgeUp?.classList.toggle("hidden", edgeScroll.scrollTop <= 4);
    edgeDown?.classList.toggle("hidden", edgeScroll.scrollTop >= edgeScroll.scrollHeight - edgeScroll.clientHeight - 4);
  }
  edgeScroll?.addEventListener("scroll", updateEdgeArrows);
  edgeUp?.addEventListener("click",   () => edgeScroll?.scrollBy({ top: -120, behavior: "smooth" }));
  edgeDown?.addEventListener("click", () => edgeScroll?.scrollBy({ top:  120, behavior: "smooth" }));

  // حباب اسم
  document.querySelectorAll(".edge-cat").forEach(item => {
    item.addEventListener("click", e => {
      const href = item.getAttribute("href");
      const isCurrent = item.getAttribute("data-slug") === currentSlug;
      if (isCurrent) { e.preventDefault(); item.scrollIntoView({ behavior: "smooth", block: "center" }); }
    });
  });

  // نرمالایز کاراکتر برای جستجوی چندزبانه
  function normalizeText(s) {
    if (!s) return '';
    return s.replace(/[ًٌٍَُِّْٰٓ]/g,'')
        .replace(/[يى]/g,'ی').replace(/[ك]/g,'ک')
        .replace(/[ةھ]/g,'ه').replace(/[إأٱ]/g,'ا')
        .replace(/[ؤ]/g,'و').replace(/[ئ]/g,'ی')
        .replace(/[ە]/g,'ه').replace(/[ۓ]/g,'ی')
        .replace(/[ے]/g,'ی')
        .replace(/[\s\u200C\u200D\u00A0]/g,'').toLowerCase();
  }
  // نرمالایز یکباره داده‌های جستجو
  searchData.forEach(e => {
    e._n = normalizeText(e.name);
    e._t = normalizeText(e.title);
    e._d = normalizeText(e.description);
    e._fv = (e.filterValues||[]).map(fv => normalizeText(fv));
    e._lp = (e.links||[]).map(l => normalizeText(l.label + ' ' + l.platform));
  });

  // Bottom Sheet
  const bsBackdrop  = document.getElementById("bs-backdrop");
  const bottomSheet = document.getElementById("bottom-sheet");
  const bsInput     = document.getElementById("bs-input");
  const bsResults   = document.getElementById("bs-results");
  const bsClear     = document.getElementById("bs-clear");
  let activeFilter  = "all";

  function openBS()  { bottomSheet?.classList.add("open"); bsBackdrop?.classList.add("open"); setTimeout(() => bsInput?.focus(), 300); }
  function closeBS() {
    bottomSheet?.classList.remove("open");
    bsBackdrop?.classList.remove("open");
    if (bsInput) bsInput.value = "";
    if (bsClear) bsClear.style.display = "none";
    activeFilter = "all";
    document.querySelectorAll(".bs-filter").forEach(b => b.classList.remove("active"));
    document.querySelector('.bs-filter[data-filter="all"]')?.classList.add("active");
    if (bsResults) bsResults.innerHTML = '<p class="bs-hint">برای جستجو تایپ کنید...</p>';
  }

  document.getElementById("nav-search")?.addEventListener("click", openBS);
  bsBackdrop?.addEventListener("click", closeBS);
  document.getElementById("bs-close-btn")?.addEventListener("click", closeBS);

  document.querySelectorAll(".bs-filter").forEach(btn => {
    btn.addEventListener("click", () => {
      document.querySelectorAll(".bs-filter").forEach(b => b.classList.remove("active"));
      btn.classList.add("active");
      activeFilter = btn.getAttribute("data-filter") ?? "all";
      renderResults(bsInput?.value ?? "");
    });
  });

  bsInput?.addEventListener("input", e => {
    const val = e.target.value;
    if (bsClear) bsClear.style.display = val ? "block" : "none";
    renderResults(val);
  });

  bsClear?.addEventListener("click", () => {
    if (bsInput) bsInput.value = "";
    bsClear.style.display = "none";
    renderResults("");
    bsInput?.focus();
  });

  function renderResults(query) {
    if (!bsResults) return;
    const q = query.trim();
    if (!q) { bsResults.innerHTML = '<p class="bs-hint">برای جستجو تایپ کنید...</p>'; return; }
    const nq = normalizeText(q);

    let entityResults = [];
    let filterResults = [];
    let linkResults   = [];

    function se(e,nq){
      if(e._n.startsWith(nq)||e._t.startsWith(nq))return 1;
      const ws=e.name.split(/[\s\u200C\u200D\u00A0]+/);
      for(const w of ws)if(normalizeText(w).startsWith(nq))return 1;
      if(e.title){const tw=e.title.split(/[\s\u200C\u200D\u00A0]+/);for(const w of tw)if(normalizeText(w).startsWith(nq))return 1;}
      return 0;
    }
    if (activeFilter === "all" || activeFilter === "entity") {
      filterResults = searchData.filter(e => e._fv.some(fv => fv.includes(nq)));
      if (!filterResults.length) {
        entityResults = searchData.filter(e => se(e,nq));
      }
    }

    // فیلتر «پلتفرم»: فقط لینک‌ها جستجو می‌شوند
    if (activeFilter === "platform") {
      searchData.forEach(entity => {
        entity.links.forEach(link => {
          const ln = normalizeText(link.label + ' ' + link.platform);
          if (ln.includes(nq)) {
            linkResults.push({ ...link, entityName: entity.name, entityColor: entity.color, entityInitial: entity.initial, entityAvatar: entity.avatar_url });
          }
        });
      });
    }

    if (!filterResults.length && !entityResults.length && !linkResults.length) {
      bsResults.innerHTML = '<p class="bs-no-result">نتیجه‌ای یافت نشد.</p>';
      return;
    }

    let out = "";

    filterResults.forEach(e => {
      out += `
        <button class="bs-entity-card" onclick="scrollToEntity('${e.id}')" type="button">
          <span class="bs-entity-name" style="color:var(--primary)">${e.name}</span>
        </button>
        <div class="bs-divider"></div>`;
    });

    if (entityResults.length) {
      if (activeFilter === "all") out += `<p class="bs-section-title">اشخاص و موسسات</p>`;
      entityResults.forEach(e => {
        out += `
          <button class="bs-entity-card" onclick="scrollToEntity('${e.id}')" type="button">
            <span class="bs-entity-name" style="color:var(--primary)">${e.name}</span>
          </button>
          <div class="bs-divider"></div>`;
      });
    }

    if (linkResults.length) {
      out += `<p class="bs-section-title">لینک‌ها</p>`;
      linkResults.forEach(l => {
        var _k=l.icon.replace('/icons/platforms/','').replace('.svg',''),_sv=PLATFORM_SVG[_k]||PLATFORM_SVG['link'];
        out += `
          <a href="${l.url}" target="_blank" rel="noreferrer noopener" class="bs-link-card">
            <div class="bs-link-icon" style="background:color-mix(in srgb,${l.color} 14%,transparent);color:${l.color}">
              <svg class="pi" style="width:20px;height:20px" viewBox="${_sv.vb}" fill="currentColor"><path d="${_sv.d}"/></svg>
            </div>
            <div>
              <div class="bs-link-platform">${l.label}</div>
              <div class="bs-link-name">${l.entityName}</div>
            </div>
          </a>
          <div class="bs-divider"></div>`;
      });
    }

    bsResults.innerHTML = out;
  }

  window.scrollToEntity = function(id) {
    closeBS();
    setTimeout(() => {
      const target = document.querySelector(`.entity-item[data-id="${id}"]`);
      if (!target) return;
      target.scrollIntoView({ behavior: "smooth", block: "center" });
      if (!target.classList.contains("open")) {
        target.classList.add("open");
        target.querySelector(".entity-row")?.setAttribute("aria-expanded", "true");
        setTimeout(() => updateScrollArrows(target.getAttribute("data-id")), 300);
      }
    }, 350);
  };

  // باز کردن entity از هش URL
  if (location.hash?.startsWith("#entity-")) {
    const entityId = location.hash.slice(8);
    setTimeout(() => window.scrollToEntity(entityId), 500);
  }

  // گزارش (delegation)
  document.getElementById("entity-list")?.addEventListener("click", async e => {
    const btn = e.target.closest(".report-btn");
    if (!btn) return;
    const name = btn.getAttribute("data-name") ?? "";
    const url = location.href;
    try {
      await fetch(`${SB_URL}/rest/v1/link_suggestions`, {
        method: "POST",
        headers: { "Content-Type": "application/json", "apikey": SB_KEY, "Authorization": `Bearer ${SB_KEY}` },
        body: JSON.stringify({ target_name: name, target_url: url, notes: "گزارش خرابی لینک" }),
      });
      alert(`گزارش خرابی برای «${name}» ثبت شد.`);
    } catch {
      alert("خطا در ثبت گزارش. لطفاً دوباره تلاش کنید.");
    }
  });
  function buildShareText(entity) {
    const enc = p => {
      const labels = { telegram: "تلگرام", instagram: "اینستاگرام", youtube: "یوتیوب",
        website: "وبسایت", tiktok: "تیک‌تاک", twitter: "توییتر", x: "ایکس",
        aparat: "آپارات", whatsapp: "واتساپ", facebook: "فیسبوک",
        castbox: "کاست‌باکس", soundcloud: "ساندکلاد", bluesky: "بلواسکای", threads: "تردز",
        email: "ایمیل", phone: "تماس", blog: "وبلاگ" };
      return labels[p] || p;
    };
    const desc = entity.description?.replace(/<[^>]*>/g,"").trim();
    let t = (desc && desc !== entity.title?.trim()) ? desc.slice(0,200) : '';
    if (entity.links?.length) {
      if (t) t += `\n\n🔗 لینک‌ها:`;
      else t = `🔗 لینک‌ها:`;
      entity.links.forEach(l => { t += `\n• ${enc(l.platform)}: ${l.url}`; });
    }
    t += `\n\n✨ لینکدونی سقیفه\n${'-'.repeat(27)}\nhttps://saqifah.vercel.app/`;
    return t;
  }

  function showFeedback(e) {
    const el = document.createElement("div");
    el.className = "copy-feedback";
    el.innerText = "متن کپی و آماده ارسال شد";
    el.style.left = `${e.clientX}px`;
    el.style.top = `${e.clientY - 40}px`;
    document.body.appendChild(el);
    setTimeout(() => { el.classList.add("fade-out"); setTimeout(() => el.remove(), 400); }, 1000);
  }

  // اشتراک (delegation)
  document.getElementById("entity-list")?.addEventListener("click", async e => {
    const btn = e.target.closest(".share-btn");
    if (!btn) return;
    const raw = btn.getAttribute("data-entity");
    if (!raw) return;
    try {
      const entity = JSON.parse(raw);
      const text = buildShareText(entity);
      if (navigator.share) await navigator.share({ title: "", text });
      else { await navigator.clipboard.writeText(text); showFeedback(e); }
    } catch {}
  });

  // ========== فیلتر سوییچینگ سمت کلاینت ==========
  const PLATFORM_MAP={
    تلگرام:{icon:"/icons/platforms/telegram.svg",color:"#29B6F6"},اینستاگرام:{icon:"/icons/platforms/instagram.svg",color:"#E1306C"},
    اکس:{icon:"/icons/platforms/x.svg",color:"#222222"},یوتیوب:{icon:"/icons/platforms/youtube.svg",color:"#FF0000"},
    "فیس بوک":{icon:"/icons/platforms/facebook.svg",color:"#1877F2"},وبسایت:{icon:"/icons/platforms/globe.svg",color:"#4CAF50"},
    سایت:{icon:"/icons/platforms/globe.svg",color:"#4CAF50"},آپارات:{icon:"/icons/platforms/aparat.svg",color:"#E7194B"},
    تیک‌تاک:{icon:"/icons/platforms/tiktok.svg",color:"#010101"},واتساپ:{icon:"/icons/platforms/whatsapp.svg",color:"#25D366"},
    ساندکلود:{icon:"/icons/platforms/soundcloud.svg",color:"#FF5500"},کاست‌باکس:{icon:"/icons/platforms/castbox.svg",color:"#F55B23"},
    تردز:{icon:"/icons/platforms/threads.svg",color:"#000000"},بلواسکای:{icon:"/icons/platforms/bluesky.svg",color:"#0285FF"},
    توییتر:{icon:"/icons/platforms/twitter.svg",color:"#1DA1F2"},پینترست:{icon:"/icons/platforms/pinterest.svg",color:"#E60023"},
    ایمیل:{icon:"/icons/platforms/envelope.svg",color:"#EA4335"},تماس:{icon:"/icons/platforms/phone.svg",color:"#10B981"},
    وبلاگ:{icon:"/icons/platforms/article.svg",color:"#FF8F00"}
  };
  function _np(s){return(s??'').replace(/[يﻱﻳﻴﻲﻯﻰ]/g,'ی').replace(/[كﻛﻜﻠﻚ]/g,'ک').replace(/[\s\u200C\u200D\u00A0\-_]+/g,'').toLowerCase().trim();}
  var _piIdx=null;
  function _piBuild(){_piIdx={};for(var k in PLATFORM_MAP)_piIdx[_np(k)]=PLATFORM_MAP[k];var en={telegram:'تلگرام',instagram:'اینستاگرام',x:'اکس',youtube:'یوتیوب',facebook:'فیس بوک',website:'وبسایت',site:'سایت',aparat:'آپارات',tiktok:'تیک‌تاک',whatsapp:'واتساپ',soundcloud:'ساندکلود',castbox:'کاست‌باکس',threads:'تردز',bluesky:'بلواسکای',twitter:'توییتر',pinterest:'پینترست',email:'ایمیل',phone:'تماس',blog:'وبلاگ'};for(var ek in en)_piIdx[ek]=PLATFORM_MAP[en[ek]];}
  function _sr(d,p){var k=d.icon.replace('/icons/platforms/','').replace('.svg','');return{icon:d.icon,color:d.color,label:p,svg:PLATFORM_SVG[k]||PLATFORM_SVG['link']};}
  function platInfo(p){if(!p)return{icon:"/icons/platforms/link.svg",color:"#888",label:"لینک",svg:PLATFORM_SVG['link']};var d=PLATFORM_MAP[p];if(d)return _sr(d,p);if(!_piIdx)_piBuild();var d2=_piIdx[_np(p)];return d2?_sr(d2,p):{icon:"/icons/platforms/link.svg",color:"#888",label:p||"لینک",svg:PLATFORM_SVG['link']};}
  function normalizeUrl(u,p){if(!u)return u;const t=u.trim();if(p==="ایمیل")return t.startsWith("mailto:")?t:`mailto:${t}`;if(p==="تماس")return t.startsWith("tel:")?t:`tel:${t}`;if(!t.startsWith("http://")&&!t.startsWith("https://"))return`https://${t}`;return t;}
  const avColors=["#5C6BC0","#26A69A","#EC407A","#AB47BC","#42A5F5","#FF7043","#66BB6A","#FF8F00"];
  function avColor(n){let h=0;for(let i=0;i<n.length;i++)h=n.charCodeAt(i)+((h<<5)-h);return avColors[Math.abs(h)%avColors.length];}
  function getInit(n){return(n?.trim()?.[0])??"؟";}

  function escHtml(s){return String(s).replace(/&/g,"&amp;").replace(/</g,"&lt;").replace(/>/g,"&gt;").replace(/"/g,"&quot;").replace(/'/g,"&#39;");}

  async function fetchAndRender(filters){
    const list=document.getElementById("entity-list");if(!list)return;
    list.innerHTML='<p class="empty-state" style="text-align:center;padding:40px;color:var(--text-dim)">در حال جستجو...</p>';
    try{
      const hdrs={"apikey":SB_KEY,"Authorization":`Bearer ${SB_KEY}`};
      const slugs=Object.keys(filters);let entityIds=null;
      if(slugs.length>0){
        const allIds=[];
        for(const slug of slugs){
          const optId=filters[slug];
          const r=await fetch(`${SB_URL}/rest/v1/entity_filter_values?filter_option_id=eq.${optId}&select=entity_id`,{headers:hdrs});
          const d=await r.json();
          if(Array.isArray(d)&&d.length)allIds.push([...new Set(d.map(x=>x.entity_id))]);else allIds.push([]);
        }
        entityIds=allIds[0];for(let i=1;i<allIds.length;i++)entityIds=entityIds.filter(id=>allIds[i].includes(id));
        if(!entityIds.length){list.innerHTML='<p class="empty-state">هنوز موردی ثبت نشده است.</p>';return;}
      }
      let url=`${SB_URL}/rest/v1/entities?select=id,name,title,description,avatar_url,verification_type,links(id,platform,url,display_order)&category_id=eq.${categoryId}&order=created_at.asc`;
      if(entityIds)url+=`&id=in.(${entityIds.join(",")})`;
      const r=await fetch(url,{headers:hdrs});const entities=await r.json();
      if(!Array.isArray(entities)){list.innerHTML='<p class="empty-state">خطا در دریافت اطلاعات.</p>';return;}
      renderEntities(entities);bindSocialScrolls();if(window.Iconify)window.Iconify.scan(list);
    }catch{
      list.innerHTML='<p class="empty-state" style="text-align:center;padding:40px;color:var(--text-dim)">خطا در دریافت اطلاعات.</p>';
    }
  }

  function renderEntities(entities){
    const list=document.getElementById("entity-list");if(!list)return;
    if(!entities.length){list.innerHTML='<p class="empty-state">هنوز موردی ثبت نشده است.</p>';return;}
    let html="";
    for(const e of entities){
      const c=avColor(e.name),init=getInit(e.name);
      const links=(e.links||[]).sort((a,b)=>(a.display_order||0)-(b.display_order||0));
      const en=escHtml(e.name),et=e.title?escHtml(e.title):"",ed=e.description?escHtml(e.description):"";
      html+=`<div class="entity-item glass-card" data-id="${e.id}" data-search="${en.toLowerCase()}">`;
      html+=`<button class="entity-row" type="button" aria-expanded="false">`;
      html+=`<div class="avatar" style="--av:${c}">`;
      if(e.avatar_url)html+=`<img src="${escHtml(e.avatar_url)}" alt="${en}" loading="lazy">`;else html+=`<span>${init}</span>`;
      html+=`</div><div class="entity-meta"><span class="entity-name">${en}`;
      if(e.verification_type==="blue")html+=` <span class="iconify verified-badge" data-icon="ph:seal-check-fill" data-width="15" data-height="15" style="color:#3b9eff"></span>`;
      else if(e.verification_type==="gold")html+=` <span class="iconify verified-badge" data-icon="ph:seal-check-fill" data-width="15" data-height="15" style="color:#d4af37"></span>`;
      html+=`</span>${et?`<span class="entity-title">${et}</span>`:""}</div>`;
      html+=`<span class="iconify chevron" data-icon="ph:caret-down" data-width="14" data-height="14"></span>`;
      html+=`</button><div class="acc-body"><div class="acc-inner">`;
      if(ed)html+=`<p class="acc-bio">${ed}</p>`;
      if(links.length){
        html+=`<div class="social-scroll-wrap"><div class="social-scroll" data-scroll-id="${e.id}">`;
        for(const l of links){
          const p=platInfo(l.platform),nu=normalizeUrl(l.url,l.platform);
          html+=`<a href="${nu}" target="_blank" rel="noreferrer noopener" class="social-icon-btn" style="--pc:${p.color}" title="${p.label}" aria-label="${p.label}"><svg class="pi" width="22" height="22" viewBox="${p.svg.vb}" fill="currentColor" role="img" aria-label="${p.label}"><path d="${p.svg.d}"/></svg></a>`;
        }
        html+=`</div><button class="scroll-arr scroll-arr--r" type="button" data-dir="right" data-target="${e.id}"><span class="iconify" data-icon="ph:caret-left" data-width="11" data-height="11"></span></button><button class="scroll-arr scroll-arr--l" type="button" data-dir="left" data-target="${e.id}"><span class="iconify" data-icon="ph:caret-right" data-width="11" data-height="11"></span></button></div>`;
      }else html+=`<p class="no-links">لینکی ثبت نشده است.</p>`;
      const ej=JSON.stringify({name:e.name,title:e.title,description:e.description,links:links.map(l=>({platform:l.platform,url:normalizeUrl(l.url,l.platform)}))}).replace(/'/g,"&#39;");
      html+=`<div class="acc-actions"><button class="action-btn report-btn" type="button" data-name="${en}"><span class="iconify" data-icon="ph:warning" data-width="14" data-height="14"></span> گزارش خرابی</button><button class="action-btn share-btn" type="button" data-entity='${ej}'><span class="iconify" data-icon="ph:share-network" data-width="14" data-height="14"></span> اشتراک‌گذاری</button></div>`;
      html+=`</div></div></div>`;
    }
    list.innerHTML=html;
  }

  function updateSearchData(entities){
    const sd=entities.map(e=>({
      id:e.id,name:e.name,title:e.title||"",description:e.description||"",avatar_url:e.avatar_url,
      color:avColor(e.name),initial:getInit(e.name),verification_type:e.verification_type,
      links:(e.links||[]).map(l=>({url:normalizeUrl(l.url,l.platform),platform:l.platform,...platInfo(l.platform)})),
      filterValues:(e.entity_filter_values??[]).map(efv=>efv.filter_options?.value??"").filter(Boolean)
    }));
    sd.forEach(e=>{e._n=normalizeText(e.name);e._t=normalizeText(e.title);e._d=normalizeText(e.description);e._fv=(e.filterValues||[]).map(fv=>normalizeText(fv));e._lp=(e.links||[]).map(l=>normalizeText(l.label+" "+l.platform));});
    searchData.length=0;searchData.push(...sd);
  }

  // کلیک روی چیپ فیلتر
  document.querySelectorAll(".filter-chip").forEach(chip=>{
    chip.addEventListener("click",async e=>{
      e.preventDefault();
      const slug=chip.dataset.filterSlug,optId=chip.dataset.optionId;
      const params=new URLSearchParams(location.search);
      if(optId)params.set(slug,optId);else params.delete(slug);
      document.querySelectorAll(`.filter-chip[data-filter-slug="${slug}"]`).forEach(c=>c.classList.toggle("active",c.dataset.optionId===optId));
      const filters={};params.forEach((v,k)=>{filters[k]=v;});
      await fetchAndRender(filters);
      const qs=params.toString();const url=qs?`/${currentSlug}?${qs}`:`/${currentSlug}`;
      history.pushState(null,"",url);
      // اسکرول به چیپ فعال
      const ac=document.querySelector(".filter-chip.active");if(ac)setTimeout(()=>ac.scrollIntoView({behavior:"smooth",inline:"center",block:"nearest"}),150);
    });
  });

  // دکمه بازگشت مرورگر
  window.addEventListener("popstate",()=>{
    const params=new URLSearchParams(location.search);
    const filters={};params.forEach((v,k)=>{filters[k]=v;});
    document.querySelectorAll(".filter-chip").forEach(c=>{const s=c.dataset.filterSlug,o=c.dataset.optionId;c.classList.toggle("active",filters[s]===o||(!filters[s]&&!o));});
    fetchAndRender(filters);
  });

  // دکمه برگشت به بالا
  (function(){
    const btn=document.getElementById("scroll-to-top");
    if(!btn)return;
    let ticking=false;
    window.addEventListener("scroll",()=>{
      if(!ticking){requestAnimationFrame(()=>{btn.classList.toggle("visible",window.scrollY>300);ticking=false;});ticking=true;}
    });
    btn.addEventListener("click",()=>window.scrollTo({top:0,behavior:"smooth"}));
  })();
</script>