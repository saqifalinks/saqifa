---
import Layout from '../layouts/Layout.astro';
import { isSupabaseConfigured, supabase } from "../lib/supabase";
import { getCategoryIcon, isLocalIcon, PLATFORMS } from "../lib/config";
import Modals from '../components/Modals.astro';

type Slide = { slide_type: "book"|"video"|"audio"|"article"; title: string; description: string; url: string; };
type Category = { id: string; name: string; slug: string; icon_name: string; };
type LegacyDailyRow = {
  day_id: number;
  book_json?:    { title?: string; description?: string; url?: string } | null;
  video_json?:   { title?: string; description?: string; url?: string } | null;
  audio_json?:   { title?: string; description?: string; url?: string } | null;
  article_json?: { title?: string; description?: string; url?: string } | null;
};

const START_DATE = new Date("2026-05-14T00:00:00Z");
function getTodayDayId(n: number) {
  const now = new Date();
  const utcDay = Date.UTC(now.getUTCFullYear(), now.getUTCMonth(), now.getUTCDate());
  const diff = Math.floor((utcDay - START_DATE.getTime()) / 86400000);
  return (diff % n) + 1;
}
function mapLegacyRow(row: LegacyDailyRow): Slide[] {
  const r: Slide[] = [];
  if (row.book_json?.title)    r.push({ slide_type:"book",    title:String(row.book_json.title),    description:String(row.book_json.description??""),    url:String(row.book_json.url??"#") });
  if (row.video_json?.title)   r.push({ slide_type:"video",   title:String(row.video_json.title),   description:String(row.video_json.description??""),   url:String(row.video_json.url??"#") });
  if (row.audio_json?.title)   r.push({ slide_type:"audio",   title:String(row.audio_json.title),   description:String(row.audio_json.description??""),   url:String(row.audio_json.url??"#") });
  if (row.article_json?.title) r.push({ slide_type:"article", title:String(row.article_json.title), description:String(row.article_json.description??""), url:String(row.article_json.url??"#") });
  return r;
}

let slides: Slide[] = [];
let categories: Category[] = [];
let totalEntities=0, totalLinks=0, platformCounts: Record<string,number> = {};

if (isSupabaseConfigured && supabase) {
  try {
    const [
      {data:catsData}, {count:totalRows},
      {count:eC}, {count:lC},
      {data:platRows},
    ] = await Promise.all([
      supabase.from("categories").select("id,name,slug,icon_name,display_order").order("display_order",{ascending:true}),
      supabase.from("daily_content").select("day_id",{count:"exact",head:true}),
      supabase.from("entities").select("id",{count:"exact",head:true}),
      supabase.from("links").select("id",{count:"exact",head:true}),
      supabase.from("links").select("platform"),
    ]);
    categories=(catsData??[]) as Category[];
    totalEntities=eC??0; totalLinks=lC??0;
    if (platRows) {
      for (const row of platRows) {
        const p = (row as any).platform;
        if (p) platformCounts[p] = (platformCounts[p]||0) + 1;
      }
    }
    if (totalRows&&totalRows>0) {
      const dayId=getTodayDayId(totalRows);
      const {data:row}=await supabase.from("daily_content").select("day_id,book_json,video_json,audio_json,article_json").eq("day_id",dayId).single();
      if (row) slides=mapLegacyRow(row as LegacyDailyRow);
      else {
        const {data:fr}=await supabase.from("daily_content").select("day_id,book_json,video_json,audio_json,article_json").order("day_id",{ascending:true}).limit(1).single();
        if (fr) slides=mapLegacyRow(fr as LegacyDailyRow);
      }
    }
  } catch {}
}

const slideIconMap: Record<string,string> = {
  book:"ph:book-bold",       video:"ph:play-circle-bold",
  audio:"ph:microphone-bold", article:"ph:file-text-bold",
};
const ctaMap: Record<string,string> = {
  book:"بیشتر بدانید", video:"بیشتر ببینید",
  audio:"بیشتر بشنوید", article:"بیشتر بخوانید",
};
const siteBanner = "درج لینک در «سَقِیفه» به معنی تایید مطالب آن نیست.";
const LANG_CAT_NAMES = new Set(['بلوچی', 'کوردی', 'عربی', 'تورکی', 'پشتو', 'تورکمنی']);
const REGION_CAT_NAMES = new Set(['مناطق']);
const langCategories = categories.filter(c => LANG_CAT_NAMES.has(c.name));
const regionsCategory = categories.find(c => REGION_CAT_NAMES.has(c.name));
const otherCategories = categories.filter(c => !LANG_CAT_NAMES.has(c.name) && !REGION_CAT_NAMES.has(c.name));
const SB_URL = import.meta.env.SUPABASE_URL;
const SB_KEY = import.meta.env.SUPABASE_ANON_KEY;
const stats = [
  {num:totalEntities,          label:"شخصیت و موسسه",  icon:"ph:users-three-bold"},
  {num:totalLinks,             label:"لینک ثبت‌شده",    icon:"ph:link-bold"},
  {num:platformCounts["تلگرام"]??0,    label:"لینک تلگرام",     icon:"simple-icons:telegram"},
  {num:platformCounts["اینستاگرام"]??0,label:"لینک اینستاگرام", icon:"simple-icons:instagram"},
];
---

<Layout title="سَقِیفَه" wide>

<!-- ══ منوی راست دسکتاپ (دسته‌ها) ══ -->
<nav class="right-nav" id="right-nav">
  <div class="rn-brand">
    <div class="rn-brand-icon">
      <img src="/icons/link-circle.svg" width="24" height="24" alt="">
    </div>
    <a href="/" class="rn-brand-text">
      <span class="rn-brand-name">سَقِيــــفه</span>
      <span class="rn-brand-subtitle">درگاه جامع هزاران مسیر دیجیتال</span>
    </a>
  </div>
  <div class="rn-cats" id="rn-cats">
    {otherCategories.map(cat=>(
      <button class="rn-cat-btn" type="button"
        data-cat-id={cat.id} data-cat-name={cat.name} data-cat-slug={cat.slug}>
        {isLocalIcon(cat.slug) ? <img src={`/icons/${cat.slug}.svg`} width="22" height="22" alt=""> : <span class="iconify" data-icon={getCategoryIcon(cat.slug)} data-width="22"></span>}
        <span class="rn-cat-label">{cat.name}</span>
      </button>
    ))}
    {regionsCategory && (
      <button class="rn-cat-btn" type="button"
        data-cat-id={regionsCategory.id} data-cat-name={regionsCategory.name} data-cat-slug={regionsCategory.slug}>
        {isLocalIcon(regionsCategory.slug) ? <img src={`/icons/${regionsCategory.slug}.svg`} width="22" height="22" alt=""> : <span class="iconify" data-icon={getCategoryIcon(regionsCategory.slug)} data-width="22"></span>}
        <span class="rn-cat-label">{regionsCategory.name}</span>
      </button>
    )}
    {langCategories.length > 0 && (
      <div class="rn-cat-group">
        <button class="rn-cat-btn group-trigger" type="button">
          <span class="iconify" data-icon="ph:translate-bold" data-width="22"></span>
          <span class="rn-cat-label">زبان</span>
          <span class="iconify group-chevron" data-icon="ph:caret-left-bold" data-width="10"></span>
        </button>
        <div class="group-dropdown" style="display:none">
          {langCategories.map(cat=>(
            <button class="rn-cat-btn group-item" type="button"
              data-cat-id={cat.id} data-cat-name={cat.name} data-cat-slug={cat.slug}>
              <span class="rn-cat-label">{cat.name}</span>
            </button>
          ))}
        </div>
      </div>
    )}
  </div>
</nav>

<!-- ══ محتوای اصلی ══ -->
<div class="main-wrap" id="main-wrap">

  <!-- هدر موبایل -->
  <header class="mobile-header">
    <a href="/" style="text-decoration:none;color:inherit">
      <h1 class="site-title">سَقِيــــفه</h1>
      <p class="site-subtitle">درگاه جامع هزاران مسیر دیجیتال</p>
    </a>
    <button id="menu-toggle" class="icon-btn" type="button">
      <span class="iconify" data-icon="ph:list-bold" data-width="22"></span>
    </button>
  </header>

  <!-- سلب مسئولیت (همیشه بالای صفحه) -->
  {siteBanner && <p class="disclaimer-box">{siteBanner}</p>}

  <!-- جستجو (دسکتاپ) -->
  <div class="desktop-search" id="desktop-search">
    <button class="ds-toggle" id="ds-toggle" type="button">
      <span class="iconify" data-icon="ph:magnifying-glass-bold" data-width="15"></span>
      <span class="ds-toggle-text">جستجو در سایت</span>
      <span class="iconify ds-chevron" data-icon="ph:caret-down-bold" data-width="11"></span>
    </button>
    <div class="ds-body" id="ds-body">
      <div class="ds-input-wrap">
        <span class="iconify" data-icon="ph:magnifying-glass-bold" data-width="16" style="color:var(--text-dim);flex-shrink:0"></span>
        <input id="ds-input" type="text" placeholder="جستجو در سراسر سایت..." autocomplete="off" />
        <button id="ds-clear" class="ds-clear" type="button" style="display:none">
          <span class="iconify" data-icon="ph:x-bold" data-width="12"></span>
        </button>
      </div>
      <div class="ds-filters" id="ds-filters">
        <button class="ds-filter active" data-filter="all" type="button">همه</button>
        <button class="ds-filter" data-filter="entity" type="button">شخصیت یا مرکز</button>
        <button class="ds-filter" data-filter="platform" type="button">پلتفرم</button>
      </div>
      <div id="ds-results" class="ds-results"></div>
    </div>
  </div>

  <!-- صفحه اول -->
  <div id="home-view">
    <!-- مطلب روز -->
    <section class="section-wrap">
      <div class="section-bar">
        <span class="iconify" data-icon="ph:newspaper-bold" data-width="15" style="color:var(--text-dim)"></span>
        <span class="section-label">مطلب روز</span>
      </div>
      <div class="glass-card daily-card">
        {slides.length>0 ? (
          <>
            <div class="daily-body">
              <div class="daily-info">
                <h2 id="slide-title">{slides[0].title}</h2>
                <p id="slide-desc">{slides[0].description}</p>
              </div>
              <div class="daily-icon-box">
                <span class="iconify" id="slide-icon"
                  data-icon={slideIconMap[slides[0].slide_type]||"ph:book-bookmark-bold"}
                  data-width="30"></span>
              </div>
            </div>
            <div class="slider-lines">
              {slides.map((_,i)=>(
                <div class="line-box"><div class={`line-fill ${i===0?"active":""}`}></div></div>
              ))}
            </div>
            <div class="daily-footer">
              <div class="slider-nav">
                <button class="nav-btn" id="prev-btn" type="button">
                  <span class="iconify" data-icon="ph:caret-right-bold" data-width="13"></span>
                </button>
                <button class="nav-btn nav-btn--pause" id="pause-btn" type="button" title="توقف">
                  <span class="iconify" data-icon="ph:pause-bold" data-width="13"></span>
                </button>
                <button class="nav-btn nav-btn--play" id="play-btn" type="button" title="پخش" style="display:none">
                  <span class="iconify" data-icon="ph:play-bold" data-width="13"></span>
                </button>
                <button class="nav-btn" id="next-btn" type="button">
                  <span class="iconify" data-icon="ph:caret-left-bold" data-width="13"></span>
                </button>
              </div>
              <a href={slides[0].url} id="slide-link" class="btn-read" target="_blank" rel="noreferrer">
                <span id="btn-text">{ctaMap[slides[0].slide_type]||"بیشتر بخوانید"}</span>
                <span class="iconify" data-icon="ph:arrow-square-out-bold" data-width="13"></span>
              </a>
            </div>
          </>
        ) : (
          <p class="empty-state">هنوز محتوای روز ثبت نشده است.</p>
        )}
      </div>
    </section>

    <!-- دسته‌ها موبایل -->
    <section class="section-wrap mobile-cats">
      <div class="section-bar">
        <span class="iconify" data-icon="ph:squares-four-bold" data-width="15" style="color:var(--text-dim)"></span>
        <span class="section-label">دسته‌بندی‌ها</span>
      </div>
      <div class="cats-grid">
        {otherCategories.map(cat=>(
          <a href={`/${cat.slug}`} class="cat-card glass-card">
            {isLocalIcon(cat.slug) ? <span class="cat-icon-box"><img src={`/icons/${cat.slug}.svg`} width="26" height="26" alt=""></span> : <span class="iconify" data-icon={getCategoryIcon(cat.slug)} data-width="26" style="color:var(--primary)"></span>}
            <span class="cat-name">{cat.name}</span>
          </a>
        ))}
      </div>

      <div class="section-bar" style="margin-top:4px">
        <span class="iconify" data-icon="ph:translate-bold" data-width="15" style="color:var(--text-dim)"></span>
        <span class="section-label">زبان و مناطق</span>
      </div>
      <div class="mob-extra-links">
        <button class="mob-lang-btn glass-card" id="mob-lang-btn" type="button">
          <span class="iconify" data-icon="ph:translate-bold" data-width="20" style="color:var(--primary)"></span>
          <span>زبان</span>
          <span class="iconify mob-chevron" data-icon="ph:caret-down-bold" data-width="12"></span>
        </button>

        {regionsCategory && (
          <a href="/regions" class="mob-region-link glass-card">
            {isLocalIcon(regionsCategory.slug) ? <span class="cat-icon-box"><img src={`/icons/${regionsCategory.slug}.svg`} width="20" height="20" alt=""></span> : <span class="iconify" data-icon={getCategoryIcon(regionsCategory.slug)} data-width="20" style="color:var(--primary)"></span>}
            <span>مناطق</span>
            <span class="iconify" data-icon="ph:arrow-left-bold" data-width="14" style="color:var(--text-dim)"></span>
          </a>
        )}
      </div>

      <!-- پاپ‌آپ زبان موبایل -->
      <div class="mob-lang-overlay" id="mob-lang-overlay" style="display:none">
        <div class="mob-lang-panel">
          <div class="mob-lang-header">
            <span class="iconify" data-icon="ph:translate-bold" data-width="22" style="color:var(--primary)"></span>
            <span>انتخاب زبان</span>
            <button class="mob-lang-close" id="mob-lang-close" type="button">
              <span class="iconify" data-icon="ph:x-bold" data-width="18"></span>
            </button>
          </div>
          <div class="mob-lang-list">
            {langCategories.map(cat=>(
              <a href={`/${cat.slug}`} class="mob-lang-item">
                <span>{cat.name}</span>
            <span class="iconify" data-icon="ph:arrow-left-bold" data-width="14" style="color:var(--text-dim)"></span>
              </a>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- دسته‌ها دسکتاپ (اسلایدر) -->
    <section class="section-wrap desktop-cats">
      <div class="section-bar">
        <span class="iconify" data-icon="ph:squares-four-bold" data-width="15" style="color:var(--text-dim)"></span>
        <span class="section-label">دسته‌بندی‌ها</span>
      </div>
      <div class="slider-wrap">
        <button class="slider-arrow slider-arrow-prev" type="button" aria-label="قبلی">‹</button>
        <div class="cats-slider">
          {otherCategories.map(cat=>(
            <button type="button" class="cat-card glass-card"
              data-cat-id={cat.id} data-cat-name={cat.name}>
              {isLocalIcon(cat.slug) ? <span class="cat-icon-box"><img src={`/icons/${cat.slug}.svg`} width="26" height="26" alt=""></span> : <span class="iconify" data-icon={getCategoryIcon(cat.slug)} data-width="26" style="color:var(--primary)"></span>}
              <span class="cat-name">{cat.name}</span>
            </button>
          ))}
          {regionsCategory && (
            <button type="button" class="cat-card glass-card"
              data-cat-id={regionsCategory.id} data-cat-name={regionsCategory.name}>
              {isLocalIcon(regionsCategory.slug) ? <span class="cat-icon-box"><img src={`/icons/${regionsCategory.slug}.svg`} width="26" height="26" alt=""></span> : <span class="iconify" data-icon={getCategoryIcon(regionsCategory.slug)} data-width="26" style="color:var(--primary)"></span>}
              <span class="cat-name">{regionsCategory.name}</span>
            </button>
          )}
        </div>
        <button class="slider-arrow slider-arrow-next" type="button" aria-label="بعدی">›</button>
      </div>
    </section>

    <!-- زبان دسکتاپ (یک ردیف) -->
    <section class="section-wrap desktop-lang-cats">
      <div class="section-bar">
        <span class="iconify" data-icon="ph:translate-bold" data-width="15" style="color:var(--text-dim)"></span>
        <span class="section-label">زبان‌ها</span>
      </div>
      <div class="cats-lang-grid">
        {langCategories.map(cat=>(
          <button type="button" class="cat-card glass-card"
            data-cat-id={cat.id} data-cat-name={cat.name}>
            <span class="cat-name">{cat.name}</span>
          </button>
        ))}
      </div>
    </section>

    <!-- شمارنده (دسکتاپ) -->
    <section class="section-wrap stats-section" id="stats-section">
      <div class="section-bar">
        <span class="iconify" data-icon="ph:chart-bar-bold" data-width="15" style="color:var(--text-dim)"></span>
        <span class="section-label">آمار</span>
      </div>
      <div class="stats-grid">
        {stats.map(s=>(
          <div class="stat-card glass-card">
            <span class="iconify" data-icon={s.icon} data-width="22" style="color:var(--primary)"></span>
            <span class="stat-num" data-target={s.num}>0</span>
            <span class="stat-label">{s.label}</span>
          </div>
        ))}
      </div>
    </section>

  </div>

  <!-- نمای دسته دسکتاپ -->
  <div id="cat-view" style="display:none">
    <div class="cat-view-header">
      <button class="cat-back-btn" id="cat-back" type="button">
        <span class="iconify" data-icon="ph:arrow-right-bold" data-width="15"></span>
      </button>
      <h2 class="cat-view-title" id="cat-view-title"></h2>
    </div>
    <div id="cat-filter-bar"></div>
    <div class="entity-list" id="entity-list">
      <div class="loading-state">
        <span class="iconify spin" data-icon="ph:spinner-bold" data-width="28" style="color:var(--primary)"></span>
      </div>
    </div>
  </div>


</div>

<!-- ══ منوی چپ دسکتاپ (اکشن‌ها) ══ -->
<aside class="left-nav" id="left-nav">
  <div class="ln-group">
    <button class="ln-btn" id="ln-theme" data-tip="تم شب / روز" type="button">
      <span class="iconify" data-icon="ph:sun-bold" data-width="20"></span>
    </button>
  </div>
  <div class="ln-divider"></div>
  <div class="ln-group">
    <button class="ln-btn open-add-trigger" data-tip="افزودن لینک" type="button">
      <span class="iconify" data-icon="ph:plus-circle-bold" data-width="20"></span>
    </button>
    <button class="ln-btn open-contact-trigger" data-tip="تماس با ما" type="button">
      <span class="iconify" data-icon="ph:headset-bold" data-width="20"></span>
    </button>
  </div>
  <div class="ln-divider"></div>
  <div class="ln-brand-btns">
    <a href="https://fanoosarea.vercel.app" target="_blank" rel="noreferrer" class="ln-btn ln-logo" data-tip="پروژه‌های دیگر">
      <span class="iconify" data-icon="ph:stack-bold" data-width="20"></span>
    </a>
    <button class="ln-btn ln-logo open-about-trigger" data-tip="درباره سَقِیفَه" type="button">
      <span class="iconify" data-icon="ph:info-bold" data-width="20"></span>
    </button>
  </div>
</aside>

<!-- منوی موبایل -->
<div id="mobile-menu-backdrop" class="mobile-menu-backdrop"></div>
<aside id="mobile-sidebar" class="mobile-sidebar">
  <div class="ms-head">
    <h2>سَقِیفه</h2>
    <button id="menu-close" class="icon-btn" type="button">
      <span class="iconify" data-icon="ph:x-bold" data-width="20"></span>
    </button>
  </div>
  <nav class="ms-links">
    <a href="#" class="ms-link open-add-trigger">
      <span class="iconify" data-icon="ph:plus-circle-bold" data-width="18"></span>افزودن لینک
    </a>
    <a href="#" class="ms-link open-contact-trigger">
      <span class="iconify" data-icon="ph:headset-bold" data-width="18"></span>تماس با ما
    </a>
    <a href="#" class="ms-link open-about-trigger">
      <span class="iconify" data-icon="ph:info-bold" data-width="18"></span>درباره ما
    </a>
    <a href="https://fanoosarea.vercel.app" target="_blank" rel="noreferrer" class="ms-link">
      <span class="iconify" data-icon="ph:stack-bold" data-width="18"></span>پروژه‌های دیگر
    </a>
  </nav>
</aside>

<!-- منوی پایین موبایل -->
<nav class="bottom-nav">
  <a href="/" class="nav-item active">
    <span class="iconify" data-icon="ph:house-bold" data-width="22"></span>
    <span>خانه</span>
  </a>
  <button class="nav-item" id="nav-search" type="button">
    <span class="iconify" data-icon="ph:magnifying-glass-bold" data-width="22"></span>
    <span>جستجو</span>
  </button>
  <button class="nav-item" id="nav-theme" type="button">
    <span class="iconify" data-icon="ph:sun-bold" data-width="22"></span>
    <span>تم</span>
  </button>
</nav>

<!-- جستجوی موبایل -->
<div class="ms-backdrop" id="ms-backdrop"></div>
<div class="ms-sheet" id="ms-sheet">
  <div class="ms-handle"></div>
  <div class="ms-search-row">
    <span class="iconify" data-icon="ph:magnifying-glass-bold" data-width="16" style="color:var(--text-dim);flex-shrink:0"></span>
    <input id="ms-input" type="text" placeholder="جستجو در سراسر سایت..." autocomplete="off" />
    <button id="ms-clear" class="ms-clear-btn" type="button" style="display:none">
      <span class="iconify" data-icon="ph:x-bold" data-width="12"></span>
    </button>
  </div>
  <div class="ms-filters">
    <button class="ms-filter active" data-filter="all" type="button">همه</button>
    <button class="ms-filter" data-filter="entity" type="button">شخصیت یا مرکز</button>
    <button class="ms-filter" data-filter="platform" type="button">پلتفرم</button>
  </div>
  <div class="ms-results" id="ms-results">
    <p class="ms-hint">برای جستجو تایپ کنید...</p>
  </div>
</div>

<Modals />
</Layout>

<style>
@font-face {
  font-family: 'GraphicSchool';
  src: url('/fonts/GraphicSchool-Regular.woff2') format('woff2');
  font-weight: normal;
  font-style: normal;
  font-display: swap;
}
*, *::before, *::after { box-sizing: border-box; }

/* ══ موبایل ══ */
.right-nav  { display: none; }
.left-nav   { display: none; }
.desktop-cats  { display: none; }
.desktop-lang-cats { display: none; }
.stats-section { display: none; }
.desktop-search { display: none; }

.main-wrap { padding-bottom: 72px; }

.mobile-header {
  display: flex; justify-content: space-between; align-items: center;
  padding: 14px 16px 10px;
}
.site-title    { font-family: 'GraphicSchool', sans-serif; font-size: 26px; font-weight: 400; color: var(--primary); margin: 0; }
.site-subtitle { font-size: 11px; color: var(--text-dim); margin: 2px 0 0; }

.icon-btn {
  width: 40px; height: 40px; border-radius: 12px;
  background: var(--surface); border: 1px solid var(--border);
  color: var(--text-main); display: inline-flex; align-items: center;
  justify-content: center; cursor: pointer; text-decoration: none; flex-shrink: 0;
}

.disclaimer-box {
  background: rgba(255,82,82,0.1); border: 1px solid rgba(255,82,82,0.3);
  color: #ffdede; font-size: 12px; border-radius: 12px;
  padding: 10px 14px; margin: 0 16px 12px;
}
html[data-theme="light"] .disclaimer-box {
  color: #8b1c1c; background: rgba(220,53,69,0.08); border-color: rgba(220,53,69,0.3);
}

/* section */
.section-wrap  { padding: 0 16px; margin-bottom: 18px; }
.section-bar   { display: flex; align-items: center; gap: 6px; margin-bottom: 10px; }
.section-label { font-size: 12px; font-weight: 800; color: var(--text-dim); }

.glass-card {
  background: color-mix(in srgb,var(--surface) 80%,transparent);
  backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);
  border: 1px solid var(--border); border-radius: 18px; overflow: hidden;
}

/* مطلب روز */
.daily-body { display: flex; gap: 12px; padding: 14px 16px 10px; align-items: flex-start; }
.daily-info { flex: 1; }
#slide-title { font-size: 14px; font-weight: 800; color: var(--text-main); margin: 0 0 6px; line-height: 1.4; }
#slide-desc  { font-size: 12px; color: var(--text-dim); line-height: 1.6; margin: 0; min-height: 36px; }
.daily-icon-box {
  width: 52px; height: 52px; border-radius: 14px;
  background: color-mix(in srgb,var(--primary) 12%,transparent);
  border: 1px solid color-mix(in srgb,var(--primary) 25%,transparent);
  display: flex; align-items: center; justify-content: center; color: var(--primary); flex-shrink: 0;
}
.slider-lines { display: flex; gap: 3px; padding: 0 16px 6px; }
.line-box { flex: 1; height: 2px; background: color-mix(in srgb,var(--text-dim) 20%,transparent); border-radius: 4px; overflow: hidden; }
.line-fill { width: 0; height: 100%; background: var(--primary); transition: width 0.3s; }
.line-fill.active { width: 100%; }
.daily-footer { display: flex; justify-content: space-between; align-items: center; padding: 8px 16px; border-top: 1px solid var(--border); }
.slider-nav { display: flex; align-items: center; gap: 14px; background: color-mix(in srgb,var(--text-dim) 8%,transparent); padding: 5px 12px; border-radius: 20px; }
.nav-btn {
  background: none; border: none; color: var(--text-dim); cursor: pointer;
  display: flex; align-items: center; padding: 5px 8px; border-radius: 8px;
  transition: color 0.15s, background 0.15s;
}
.nav-btn:hover { color: var(--primary); }
.nav-btn--pause { background: color-mix(in srgb,var(--primary) 10%,transparent); color: var(--primary); }
.nav-btn--play { background: none; color: var(--text-dim); }
.nav-btn--play:hover { background: color-mix(in srgb,var(--primary) 10%,transparent); color: var(--primary); }
.btn-read { display: flex; align-items: center; gap: 5px; color: var(--primary); text-decoration: none; font-size: 11px; font-weight: 800; }

/* دسته‌ها موبایل */
.cats-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 10px; }

/* لینک‌های اضافی موبایل (زبان / مناطق) */
.mob-extra-links { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; margin-top: 10px; }
.mob-lang-btn, .mob-region-link {
  display: flex; flex-direction: column; align-items: center; gap: 4px; padding: 12px 10px;
  font-size: 13px; font-weight: 800; font-family: inherit;
  color: var(--text-main); cursor: pointer; width: 100%;
  border: none; text-decoration: none;
}
.mob-lang-btn .mob-chevron { margin: 0; }
.mob-region-link .iconify:last-child { margin: 0; }
.mob-chevron { transition: transform 0.2s; }
.mob-lang-btn[aria-expanded="true"] .mob-chevron { transform: rotate(180deg); }

/* پاپ‌آپ زبان موبایل */
.mob-lang-overlay {
  position: fixed; inset: 0; z-index: 9999;
  background: color-mix(in srgb,#000 40%,transparent);
  display: flex; align-items: flex-end; justify-content: center;
}
.mob-lang-panel {
  width: 100%; max-width: 420px;
  background: var(--bg);
  border-radius: 24px 24px 0 0;
  padding: 20px 20px 32px;
  box-shadow: 0 -4px 30px rgba(0,0,0,0.15);
  animation: slideUp 0.2s ease-out;
}
@keyframes slideUp { from { transform: translateY(100%); } to { transform: translateY(0); } }
.mob-lang-header {
  display: flex; align-items: center; gap: 10px; margin-bottom: 18px;
  font-size: 16px; font-weight: 800;
}
.mob-lang-close {
  margin-right: auto; background: none; border: none;
  cursor: pointer; color: var(--text-dim); padding: 4px;
}
.mob-lang-list { display: flex; flex-direction: column; gap: 4px; }
.mob-lang-item {
  display: flex; align-items: center; gap: 12px;
  padding: 14px 16px; border-radius: 14px;
  text-decoration: none; color: var(--text-main);
  font-size: 15px; font-weight: 700;
  transition: background 0.15s;
  background: color-mix(in srgb,var(--primary) 5%,transparent);
  border: 1px solid color-mix(in srgb,var(--primary) 10%,transparent);
}
.mob-lang-item:hover { background: color-mix(in srgb,var(--primary) 12%,transparent); }

.cat-card {
  display: flex; flex-direction: column; align-items: center; gap: 6px;
  text-decoration: none; padding: 18px 10px; border-radius: 16px;
  transition: transform 0.2s, border-color 0.2s;
}
.cat-card:hover { transform: translateY(-2px); border-color: var(--primary); }
.cat-name { font-size: 13px; font-weight: 800; color: var(--text-main); text-align: center; }
.cat-icon-box { display:flex; align-items:center; justify-content:center; width:38px; height:38px; border-radius:50%; background:var(--primary); flex-shrink:0; }

/* اسلایدر دسکتاپ */
.cats-slider-wrap { position: relative; }
.cats-slider { gap: 10px; scroll-behavior: smooth; scrollbar-width: none; padding: 4px 2px 8px; }
.cats-slider::-webkit-scrollbar { display: none; }

.slider-arr {
  position: absolute; top: 50%; transform: translateY(-50%);
  width: 30px; height: 30px; border-radius: 50%;
  background: var(--surface); border: 1px solid var(--border); color: var(--text-dim);
  display: flex; align-items: center; justify-content: center;
  cursor: pointer; box-shadow: 0 2px 10px color-mix(in srgb,#000 12%,transparent); z-index: 2;
  transition: color 0.15s;
}
.slider-arr:hover { color: var(--primary); }
.slider-arr--r { right: 0; }
.slider-arr--l { left: 0; }

/* شمارنده */
.stats-grid { display: grid; grid-template-columns: repeat(4,1fr); gap: 12px; }
.stat-card { display: flex; flex-direction: column; align-items: center; gap: 6px; padding: 18px 10px; border-radius: 16px; }
.stat-num  { font-size: 26px; font-weight: 900; color: var(--text-main); }
.stat-label{ font-size: 11px; color: var(--text-dim); font-weight: 700; text-align: center; }
@keyframes spin { to { transform: rotate(360deg); } }
.spin { animation: spin 1s linear infinite; }

/* نمای دسته */
#cat-view { animation: catFadeIn 0.25s ease; }
@keyframes catFadeIn { from { opacity: 0; transform: translateY(8px); } to { opacity: 1; transform: translateY(0); } }

.cat-view-header {
  display: flex; align-items: center; gap: 12px; padding: 14px 16px;
  border-bottom: 1px solid var(--border); margin-bottom: 12px;
  position: sticky; top: 0; background: var(--surface); z-index: 10;
}
.cat-back-btn {
  width: 36px; height: 36px; border-radius: 10px;
  background: color-mix(in srgb,var(--text-dim) 8%,transparent); border: 1px solid var(--border);
  color: var(--text-main); display: flex; align-items: center; justify-content: center; cursor: pointer;
  transition: background 0.15s, border-color 0.15s;
}
.cat-back-btn:hover { border-color: var(--primary); color: var(--primary); }
.cat-view-title { font-size: 18px; font-weight: 900; color: var(--text-main); margin: 0; letter-spacing: 0.1em; }
.entity-list { display: flex; flex-direction: column; gap: 10px; padding: 0 14px; }
.loading-state { display: flex; justify-content: center; padding: 40px; }
.empty-state { text-align: center; color: var(--text-dim); font-size: 13px; padding: 24px; margin: 0; }
/* منوی پایین موبایل */
.bottom-nav {
  position: fixed; bottom: 0; left: 50%; transform: translateX(-50%);
  width: 100%; max-width: 680px; display: flex;
  background: var(--surface); border-top: 1px solid var(--border);
  z-index: 40; padding-bottom: env(safe-area-inset-bottom);
}
.nav-item {
  flex: 1; display: flex; flex-direction: column; align-items: center; justify-content: center;
  gap: 3px; padding: 9px 0; color: var(--text-dim); text-decoration: none;
  font-size: 10px; font-weight: 700; background: none; border: none;
  cursor: pointer; font-family: inherit; transition: color 0.15s;
}
.nav-item:hover, .nav-item.active { color: var(--primary); }

/* منوی موبایل کشویی */
.mobile-menu-backdrop {
  position: fixed; inset: 0; background: rgba(0,0,0,0.45);
  opacity: 0; visibility: hidden; transition: 0.2s; z-index: 90;
}
.mobile-menu-backdrop.open { opacity: 1; visibility: visible; }
.mobile-sidebar {
  position: fixed; top: 0; right: -300px; width: 260px; height: 100%;
  background: var(--surface); border-left: 1px solid var(--border);
  padding: 20px 16px; z-index: 100; transition: right 0.25s ease;
  display: flex; flex-direction: column; gap: 12px;
}
.mobile-sidebar.open { right: 0; }
.ms-head { display: flex; align-items: center; justify-content: space-between; padding-bottom: 12px; border-bottom: 1px solid var(--border); }
.ms-head h2 { margin: 0; font-size: 16px; font-weight: 900; color: var(--text-main); }
.ms-links { display: flex; flex-direction: column; gap: 6px; }
.ms-link {
  display: flex; align-items: center; gap: 10px; padding: 12px 14px; border-radius: 12px;
  background: color-mix(in srgb,var(--text-dim) 6%,transparent); border: 1px solid var(--border);
  color: var(--text-main); text-decoration: none; font-size: 13px; font-weight: 600;
  cursor: pointer; font-family: inherit; transition: border-color 0.15s, color 0.15s;
}
.ms-link:hover { border-color: var(--primary); color: var(--primary); }

/* جستجوی موبایل (Bottom Sheet) */
.ms-backdrop {
  position: fixed; inset: 0; background: rgba(0,0,0,0.45);
  backdrop-filter: blur(3px); z-index: 80;
  opacity: 0; pointer-events: none; transition: opacity 0.25s;
}
.ms-backdrop.open { opacity: 1; pointer-events: auto; }

.ms-sheet {
  position: fixed; bottom: 0; left: 50%; transform: translateX(-50%) translateY(100%);
  width: 100%; max-width: 680px; height: 82vh;
  background: var(--surface); border-radius: 22px 22px 0 0;
  border: 1px solid var(--border); border-bottom: none;
  z-index: 81; display: flex; flex-direction: column;
  transition: transform 0.3s cubic-bezier(0.34,1.2,0.64,1);
  padding-bottom: env(safe-area-inset-bottom);
}
.ms-sheet.open { transform: translateX(-50%) translateY(0); }
.ms-handle { width: 40px; height: 4px; background: var(--border); border-radius: 4px; margin: 12px auto 10px; flex-shrink: 0; }

.ms-search-row {
  display: flex; align-items: center; gap: 10px;
  margin: 0 16px 10px; padding: 10px 14px;
  background: color-mix(in srgb,var(--text-dim) 8%,transparent);
  border-radius: 14px; border: 1px solid var(--border); flex-shrink: 0;
}
.ms-search-row input {
  flex: 1; background: none; border: none; outline: none;
  font-size: 14px; color: var(--text-main); font-family: inherit; direction: rtl;
}
.ms-clear-btn { background: none; border: none; color: var(--text-dim); cursor: pointer; padding: 2px; }

.ms-filters { display: flex; gap: 8px; padding: 0 16px 12px; flex-shrink: 0; }
.ms-filter {
  padding: 6px 18px; border-radius: 20px; border: 1px solid var(--border);
  background: none; color: var(--text-dim); font-size: 12px; font-weight: 700;
  cursor: pointer; font-family: inherit; transition: all 0.15s;
}
.ms-filter.active { background: var(--primary); border-color: var(--primary); color: #fff; }

:global(.ms-results) { flex: 1; overflow-y: auto; padding: 0 16px 16px; }
:global(.ms-hint, .ms-no-result) { text-align: center; color: var(--text-dim); font-size: 13px; padding: 32px 16px; margin: 0; }
:global(.ms-section-title) { font-size: 11px; font-weight: 800; color: var(--text-dim); padding: 10px 16px 4px; margin: 0; }
:global(.ms-divider) { height: 1px; background: var(--border); margin: 0 16px; opacity: 0.4; }

:global(.ms-entity-card) {
  display: flex; align-items: center; gap: 12px; padding: 12px 16px; min-height: 44px;
  cursor: pointer; transition: background 0.12s;
  background: none; border: none; font-family: inherit; font-size: inherit;
  text-align: right; width: 100%; color: inherit; border-radius: 12px;
}
:global(.ms-entity-card:hover) { background: color-mix(in srgb,var(--primary) 5%,transparent); }
:global(.ms-entity-name) { font-size: 14px; font-weight: 800; color: var(--text-main); }

:global(.ms-link-card) {
  display: flex; align-items: center; gap: 12px; padding: 10px 16px;
  text-decoration: none; transition: background 0.12s;
}
:global(.ms-link-card:hover) { background: color-mix(in srgb,var(--primary) 5%,transparent); }
:global(.ms-link-icon) {
  width: 40px; height: 40px; border-radius: 12px;
  display: flex; align-items: center; justify-content: center; font-size: 18px; flex-shrink: 0;
}
:global(.ms-link-platform) { font-size: 11px; color: var(--text-dim); }
:global(.ms-link-name) { font-size: 13px; font-weight: 800; color: var(--text-main); }

/* ══════════════════════════════
   دسکتاپ
══════════════════════════════ */
@media (min-width: 768px) {

  /* override کامل page-shell از global.css */
  :global(.page-shell),
  :global(.page-shell--wide) {
    display: flex !important;
    flex-direction: row !important;
    align-items: stretch !important;
    height: 100vh !important;
    max-height: 100vh !important;
    padding: 0 !important;
    max-width: 100vw !important;
    width: 100vw !important;
    overflow: visible !important;
    margin: 0 !important;
    background: var(--primary);
  }

  /* منوی راست (دسته‌ها) — سمت راست صفحه */
  .right-nav {
    display: flex; flex-direction: column;
    width: 280px; flex-shrink: 0;
    height: 100vh; position: sticky; top: 0;
    background: transparent;
    overflow: visible;
    isolation: isolate;
    z-index: 10;
    order: 1;
  }
  .rn-brand {
    display: flex; align-items: center; gap: 12px; padding: 24px 22px;
    background: transparent;
    border-bottom: 1px solid color-mix(in srgb,#fff 12%,transparent);
    z-index: 2; flex-shrink: 0;
  }
  .rn-brand-icon {
    width: 42px; height: 42px; border-radius: 14px;
    display: flex; align-items: center; justify-content: center;
    background: color-mix(in srgb,#fff 18%,transparent);
    color: #fff; flex-shrink: 0;
  }
  .rn-brand-text { display: flex; flex-direction: column; gap: 2px; }
  .rn-brand-name { font-family: 'GraphicSchool', sans-serif; font-size: 22px; font-weight: 400; color: #fff; }
  .rn-brand-subtitle { font-size: 11px; color: color-mix(in srgb,#fff 60%,transparent); font-weight: 600; }
  .rn-cats { display: flex; flex-direction: column; gap: 6px; padding: 18px 12px; flex: 1; overflow-y: auto; }
  .rn-cat-btn {
    display: flex; align-items: center; gap: 14px; padding: 16px 18px; border-radius: 16px;
    color: color-mix(in srgb,#fff 70%,transparent); font-size: 15px; font-weight: 700;
    background: transparent; border: none; cursor: pointer; font-family: inherit;
    text-align: right; width: 100%; transition: all 0.2s;
    position: relative;
  }
  .rn-cat-btn:hover { background: color-mix(in srgb,#fff 10%,transparent); color: #fff; }
  .rn-cat-btn.active {
    background: color-mix(in srgb,#fff 14%,transparent);
    color: #fff; font-weight: 800;
  }
  .rn-cat-btn.active::before {
    content: ''; position: absolute; right: 0; top: 50%; transform: translateY(-50%);
    width: 3px; height: 20px; border-radius: 0 4px 4px 0;
    background: #fff;
  }

  .rn-cat-group { position: relative; flex-shrink: 0; }
  .group-trigger { display: flex; align-items: center; gap: 14px; width: 100%; cursor: pointer; }
  .group-chevron { margin-right: auto; transition: transform 0.2s; }
  .rn-cat-group:hover .group-chevron { transform: rotate(180deg); }
  .group-dropdown {
    display: none;
    position: fixed;
    z-index: 9999;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 6px;
    min-width: 180px;
    box-shadow: 0 8px 32px color-mix(in srgb,#000 15%,transparent);
    flex-direction: column;
    gap: 2px;
  }
  .group-item {
    white-space: nowrap;
    border-radius: 10px;
    padding: 10px 14px !important;
    background: transparent !important;
    color: var(--text-main) !important;
    border: 1px solid transparent;
    font-size: 14px;
    font-weight: 700;
    font-family: inherit;
    text-align: right;
    width: 100%;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 10px;
    transition: all 0.15s;
  }
  .group-item:hover {
    border-color: var(--primary) !important;
    background: color-mix(in srgb,var(--primary) 8%,transparent) !important;
    color: var(--primary) !important;
  }

  /* محتوای اصلی */
  .main-wrap {
    flex: 1; min-width: 0; min-height: 0; padding: 28px 36px 40px;
    overflow-y: auto; order: 2;
    background: var(--bg);
    border-radius: 24px;
    margin: 10px 4px 10px 10px;
  }

  /* منوی چپ (اکشن‌ها) — سمت چپ صفحه */
  .left-nav {
    display: flex; flex-direction: column; align-items: center; justify-content: flex-end;
    width: 64px; flex-shrink: 0; height: 100vh; position: sticky; top: 0;
    background: transparent;
    padding: 16px 0 20px; gap: 2px; order: 3;
  }
  .ln-group { display: flex; flex-direction: column; align-items: center; gap: 2px; width: 100%; }
  .ln-group-label { font-size: 9px; font-weight: 800; color: color-mix(in srgb,#fff 35%,transparent); letter-spacing: 0.1em; margin: 6px 0 2px; }
  .ln-btn {
    position: relative; width: 44px; height: 44px; border-radius: 12px;
    background: transparent; border: none; color: color-mix(in srgb,#fff 65%,transparent);
    display: flex; align-items: center; justify-content: center;
    cursor: pointer; text-decoration: none; transition: all 0.2s;
  }
  .ln-btn:hover { color: #fff; background: color-mix(in srgb,#fff 10%,transparent); transform: scale(1.05); }
  .ln-btn:active { transform: scale(0.95); }
  .ln-btn::after {
    content: attr(data-tip); position: absolute; left: calc(100% + 12px);
    top: 50%; transform: translateY(-50%); background: var(--surface);
    border: 1px solid var(--border); color: var(--text-main);
    font-size: 11px; font-weight: 700; padding: 5px 12px; border-radius: 20px;
    white-space: nowrap; box-shadow: 0 2px 10px color-mix(in srgb,#000 12%,transparent);
    opacity: 0; pointer-events: none; transition: opacity 0.2s; z-index: 200;
  }
  .ln-btn:hover::after { opacity: 1; }
  .ln-divider { width: 28px; height: 1px; background: color-mix(in srgb,#fff 25%,transparent); margin: 4px 0; }
  .ln-brand-btns { display: flex; flex-direction: column; align-items: center; gap: 0; margin-top: auto; }
  .ln-logo { margin-top: 0; }
  .ln-logo:hover::after { opacity: 1; }

  /* مخفی در دسکتاپ */
  .mobile-header { display: none; }
  .bottom-nav { display: none !important; }
  .mobile-menu-backdrop, .mobile-sidebar { display: none !important; }
  .ms-backdrop, .ms-sheet { display: none !important; }
  .mobile-cats { display: none; }

  /* نمایش در دسکتاپ */
  .desktop-cats  { display: block; }
  .desktop-lang-cats { display: block; }
  .stats-section { display: block; }

  .section-wrap    { padding: 0; }
  .disclaimer-box  { margin: 0 0 14px; }

  #slide-title { font-size: 18px; }
  #slide-desc  { font-size: 13px; }
  .daily-body  { padding: 20px 22px 14px; }
  .daily-icon-box { width: 64px; height: 64px; }

  .slider-wrap {
    position: relative;
  }
  .cats-slider {
    display: flex;
    gap: 10px;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    -webkit-overflow-scrolling: touch;
    overscroll-behavior-x: contain;
    padding: 4px 0;
  }
  .cats-slider .cat-card {
    flex: 1 0 0;
    min-width: 130px;
    scroll-snap-align: start;
    padding: 30px 10px;
    border-radius: 16px;
  }
  .slider-arrow {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 2;
    width: 34px;
    height: 34px;
    border-radius: 50%;
    border: none;
    background: var(--surface);
    border: 1px solid var(--border);
    box-shadow: 0 2px 8px color-mix(in srgb,#000 13%,transparent);
    cursor: pointer;
    font-size: 22px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--text-main);
    line-height: 1;
    padding: 0;
    transition: opacity 0.15s, transform 0.15s;
  }
  .slider-arrow:hover { opacity: 0.8; transform: translateY(-50%) scale(1.08); }
  .slider-arrow-prev { right: -14px; }
  .slider-arrow-next { left: -14px; }
  .cats-lang-grid {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 12px;
  }
  .cats-lang-grid .cat-card { padding: 18px 10px; border-radius: 16px; }
  .cats-lang-grid .cat-name { font-size: 15px; }

  /* نمای دسته در دسکتاپ */
  #cat-view { padding: 0; }
  .cat-view-header {
    position: static; margin-bottom: 16px; padding: 0 0 14px;
    background: none; border-bottom: 1px solid var(--border);
  }
  .cat-view-title { font-size: 22px; }
  .entity-list { padding: 0; columns: 2; column-gap: 12px; display: block; }
  .entity-list > * { break-inside: avoid; margin-bottom: 12px; }

  /* جستجوی دسکتاپ */
  .desktop-search { display: block; margin-bottom: 20px; }
  .ds-toggle {
    display: flex; align-items: center; gap: 8px;
    width: 100%; padding: 10px 16px;
    background: color-mix(in srgb,var(--surface) 75%,transparent);
    border: 1px dashed var(--border); border-radius: 14px;
    color: var(--text-dim); cursor: pointer;
    font-family: inherit; font-size: 13px; font-weight: 600;
    transition: all 0.2s;
  }
  .ds-toggle:hover { border-color: var(--primary); color: var(--text-main); background: color-mix(in srgb,var(--primary) 4%,transparent); }
  .ds-chevron { margin-right: auto; transition: transform 0.25s; }
  .ds-toggle.open .ds-chevron { transform: rotate(180deg); }

  .ds-body {
    display: none; margin-top: 10px;
    background: color-mix(in srgb,var(--surface) 70%,transparent);
    backdrop-filter: blur(12px); border: 1px solid var(--border);
    border-radius: 18px; padding: 16px;
    animation: dsFadeIn 0.2s ease;
  }
  .ds-body.open { display: block; }
  @keyframes dsFadeIn { from { opacity: 0; transform: translateY(-6px); } to { opacity: 1; transform: translateY(0); } }

  .ds-input-wrap {
    display: flex; align-items: center; gap: 10px;
    padding: 10px 14px;
    background: color-mix(in srgb,var(--bg) 40%,transparent);
    border: 1px solid var(--border); border-radius: 12px;
  }
  .ds-input-wrap:focus-within { border-color: var(--primary); }
  .ds-input-wrap input {
    flex: 1; background: none; border: none; outline: none;
    font-size: 14px; color: var(--text-main); font-family: inherit; direction: rtl;
  }
  .ds-clear { background: none; border: none; color: var(--text-dim); cursor: pointer; padding: 2px; }

  .ds-filters { display: flex; gap: 8px; margin-top: 10px; flex-wrap: wrap; }
  .ds-filter {
    padding: 5px 16px; border-radius: 20px; border: 1px solid var(--border);
    background: none; color: var(--text-dim); font-size: 11px; font-weight: 700;
    cursor: pointer; font-family: inherit; transition: all 0.15s;
  }
  .ds-filter:hover { border-color: color-mix(in srgb,var(--primary) 40%,transparent); color: var(--primary); }
  .ds-filter.active { background: var(--primary); border-color: var(--primary); color: #fff; }

  .ds-results { margin-top: 10px; max-height: 360px; overflow-y: auto; }
  :global(.ds-item) {
    display: flex; align-items: center; gap: 10px; padding: 10px 12px; min-height: 40px;
    border-radius: 10px; cursor: pointer;
    background: none; border: none; font-family: inherit; font-size: inherit;
    text-align: right; width: 100%; color: var(--text-main); transition: background 0.12s;
  }
  :global(.ds-item:hover) { background: color-mix(in srgb,var(--primary) 6%,transparent); }
  :global(.ds-item-title) { font-size: 13px; font-weight: 700; }
  :global(.ds-divider) { height: 1px; background: var(--border); margin: 0 10px; opacity: 0.4; }
  :global(.ds-empty) { text-align: center; color: var(--text-dim); font-size: 13px; padding: 20px; }
  :global(.ds-section-title) { font-size: 10px; font-weight: 800; color: var(--text-dim); padding: 8px 10px 4px; letter-spacing: 0.05em; }
}
</style>

